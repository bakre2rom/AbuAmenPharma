@page
@model LoginModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - أبو آمن ERP</title>
    <link rel="icon" type="image/svg+xml" href="~/img/abuamen-mark.svg" />
    <link href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <style>
        :root {
            --primary-color: #0b4f87;
            --secondary-color: #2ca79f;
            --bg-light: #f4f7f9;
            --text-main: #2c3e50;
            --text-muted: #7f8c8d;
            --card-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
        }

        body {
            background-color: var(--bg-light);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow: hidden; /* Prevent scrolling for the main container */
            background-image: radial-gradient(circle at 0% 0%, rgba(11, 79, 135, 0.03) 0%, transparent 50%),
                              radial-gradient(circle at 100% 100%, rgba(44, 167, 159, 0.03) 0%, transparent 50%);
        }

        .login-container {
            width: 100%;
            max-width: 900px;
            padding: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            background: #fff;
            border-radius: 20px;
            box-shadow: var(--card-shadow);
            overflow: hidden;
            display: flex;
            width: 100%;
            max-height: 90vh; /* Ensure card is never taller than screen */
            border: 1px solid rgba(0,0,0,0.05);
        }

        .login-brand-panel {
            flex: 1;
            background: linear-gradient(135deg, var(--primary-color) 0%, #1a6ab3 100%);
            color: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 30px;
            position: relative;
            overflow: hidden;
        }

        .login-form-panel {
            flex: 1.25;
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .brand-logo {
            width: 90px;
            height: 90px;
            background: #fff;
            border-radius: 22px;
            padding: 15px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
            margin-bottom: 20px;
            position: relative;
            z-index: 2;
        }

        .brand-logo img {
            width: 100%;
            height: 100%;
        }

        .brand-title {
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: 1.5px;
            margin-bottom: 5px;
            position: relative;
            z-index: 2;
        }

        .brand-subtitle {
            font-size: 0.95rem;
            opacity: 0.85;
            font-weight: 500;
            margin-bottom: 20px;
            position: relative;
            z-index: 2;
        }

        .brand-features {
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.7);
            list-style: none;
            padding: 0;
            margin: 0;
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 280px;
        }

        .brand-features li {
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .brand-features i {
            color: var(--secondary-color);
            background: #fff;
            border-radius: 50%;
            width: 18px;
            height: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.65rem;
            flex-shrink: 0;
        }

        .form-header {
            margin-bottom: 25px;
        }

        .form-header h2 {
            font-weight: 800;
            color: var(--primary-color);
            font-size: 1.5rem;
            margin-bottom: 5px;
        }

        .form-header p {
            color: var(--text-muted);
            font-size: 0.88rem;
            margin-bottom: 0;
        }

        .form-label {
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 5px;
            font-size: 0.85rem;
        }

        .form-control {
            border-radius: 10px;
            padding: 10px 15px;
            border: 2px solid #eef2f5;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            background-color: #fcfdfe;
        }

        .form-control:focus {
            border-color: var(--secondary-color);
            box-shadow: 0 0 0 3px rgba(44, 167, 159, 0.08);
            background-color: #fff;
        }

        .btn-login {
            background: linear-gradient(135deg, var(--primary-color) 0%, #1a6ab3 100%);
            border: none;
            border-radius: 10px;
            padding: 12px;
            font-weight: 700;
            font-size: 1rem;
            color: #fff;
            box-shadow: 0 6px 12px rgba(11, 79, 135, 0.15);
            transition: all 0.3s ease;
            margin-top: 15px;
        }

        .btn-login:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 18px rgba(11, 79, 135, 0.2);
            color: #fff;
        }

        .form-footer {
            margin-top: 20px;
            text-align: center;
            font-size: 0.78rem;
            color: var(--text-muted);
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.85rem;
            color: var(--text-muted);
            cursor: pointer;
        }

        .remember-me input {
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

        @@media (max-height: 700px) {
            .brand-features, .brand-subtitle { display: none; }
            .login-card { min-height: auto; }
            .form-header { margin-bottom: 15px; }
            .form-footer { margin-top: 10px; }
        }

        @@media (max-width: 991px) {
            body { overflow: auto; height: auto; padding: 20px 0; }
            .login-card { flex-direction: column; max-height: none; }
            .login-brand-panel, .login-form-panel { padding: 30px; }
            .brand-logo { width: 70px; height: 70px; margin: 0 auto 15px; }
            .brand-features { display: none; }
        }
    </style>
</head>
<body>

<div class="login-container">
    <div class="login-card">
        <!-- Brand Panel -->
        <div class="login-brand-panel">
            <div class="brand-logo">
                <img src="~/img/abuamen-mark.svg" asp-append-version="true" alt="شعار أبو آمن" />
            </div>
            <h1 class="brand-title">ABU AMEN</h1>
            <p class="brand-subtitle">نظام الصيدلة الموحد</p>
            
            <ul class="brand-features">
                <li><i class="bi bi-check"></i> إدارة المبيعات والمشتريات</li>
                <li><i class="bi bi-check"></i> تتبع المخزون والباتشات</li>
                <li><i class="bi bi-check"></i> حسابات الموردين والعملاء</li>
            </ul>
        </div>

        <!-- Form Panel -->
        <div class="login-form-panel">
            <div class="form-header">
                <h2>تسجيل الدخول</h2>
                <p>يرجى إدخال بياناتك للوصول للنظام</p>
            </div>

            <form id="account" method="post">
                <div asp-validation-summary="All" class="text-danger mb-2 small"></div>

                <div class="mb-3">
                    <label class="form-label">البريد الإلكتروني</label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small" style="font-size: 0.75rem;"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">كلمة المرور</label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger small" style="font-size: 0.75rem;"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <label class="remember-me">
                        <input class="form-check-input mt-0" asp-for="Input.RememberMe" />
                        تذكرني
                    </label>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="small text-muted text-decoration-none" style="font-size: 0.8rem;">نسيت كلمة المرور؟</a>
                </div>

                <button id="login-submit" type="submit" class="btn btn-login w-100">دخول للنظام</button>
            </form>

            <div class="form-footer">
                <p class="mb-1">&copy; @DateTime.Now.Year - صيدليات أبو آمن</p>
                <p class="text-muted tiny mb-0">v3.4.0 ERP Core</p>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<partial name="_ValidationScriptsPartial" />

</body>
</html>
