@model PurchaseReturn
@{
    ViewData["Title"] = $"تفاصيل مرتجع مشتريات #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-1">
    <div>
        <h4 class="mb-0 fw-bold text-dark"><i class="bi bi-arrow-return-left me-2 text-primary"></i> تفاصيل مرتجع مشتريات #@Model.Id</h4>
        <div class="text-muted small mt-1">
            <span class="me-2">المورد: <strong class="text-dark">@Model.Supplier?.Name</strong></span> |
            <span class="mx-2">فاتورة شراء: <strong class="text-dark">#@Model.PurchaseId</strong></span> |
            <span class="mx-2">التاريخ: <strong class="text-dark">@Model.ReturnDate.ToString("yyyy-MM-dd")</strong></span>
        </div>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-sm btn-outline-secondary px-3 rounded-pill" asp-action="Index">
            <i class="bi bi-arrow-right me-1"></i> رجوع
        </a>
        <a class="btn btn-sm btn-success px-3 rounded-pill shadow-sm" target="_blank" asp-action="Print" asp-route-id="@Model.Id">
            <i class="bi bi-printer me-1"></i> طباعة
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-5">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-0">
                <table class="table table-sm table-borderless mb-0">
                    <tr class="bg-light">
                        <td class="p-3 fw-bold text-primary">إجمالي قيمة المرتجع</td>
                        <td class="p-3 pe-4 text-end fw-bold text-primary" style="font-size: 1.25rem;">@Model.Total.ToString("N2")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
        <div class="col-md-7">
            <div class="card shadow-sm border-0 h-100 rounded-3">
                <div class="card-body">
                    <h6 class="fw-bold text-muted mb-2 small"><i class="bi bi-sticky me-1"></i> ملاحظات المرتجع</h6>
                    <p class="mb-0 text-dark">@Model.Notes</p>
                </div>
            </div>
        </div>
    }
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white border-0 py-3">
        <h6 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2"></i> بنود المرتجع</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-3" style="width: 50px;">#</th>
                        <th>الصنف</th>
                        <th class="text-center">الكمية</th>
                        <th class="text-center">سعر الشراء</th>
                        <th class="text-center">الإجمالي</th>
                        <th class="text-center">رقم الباتش</th>
                        <th class="pe-3 text-center">تاريخ الانتهاء</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var i = 1;
                        foreach (var line in Model.Lines)
                        {
                            <tr>
                                <td class="ps-3 text-muted">@(i++)</td>
                                <td><span class="fw-bold text-dark">@line.Item?.NameAr</span></td>
                                <td class="text-center">@line.Qty.ToString("N0")</td>
                                <td class="text-center">@line.UnitCost.ToString("N2")</td>
                                <td class="text-center fw-bold">@line.LineTotal.ToString("N2")</td>
                                <td class="text-center"><span class="badge bg-light text-dark border fw-normal">@line.Batch?.BatchNo</span></td>
                                <td class="pe-3 text-center">@((line.Batch != null) ? line.Batch.ExpiryDate.ToString("yyyy-MM-dd") : "-")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
