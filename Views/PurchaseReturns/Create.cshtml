@model IEnumerable<Purchase>
@{
    ViewData["Title"] = "مرتجع مشتريات (اختيار فاتورة)";
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-1">
    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-arrow-return-right me-1"></i> إنشاء مرتجع مشتريات</h5>
    <div class="small text-muted">اختر فاتورة شراء مسجلة لعمل مرتجع جزئي أو كلي منها</div>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-3">
        <div class="table-responsive">
            <table id="purchaseTable" class="table table-sm table-hover align-middle mb-0" style="font-size: 0.88rem;">
                <thead class="table-light text-muted">
                    <tr>
                        <th style="width:80px;">رقم</th>
                        <th>التاريخ</th>
                        <th>المورد</th>
                        <th class="text-end">الإجمالي</th>
                        <th style="width:120px;" class="text-center">إجراء</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td><span class="fw-bold text-dark">#@p.Id</span></td>
                            <td>@p.PurchaseDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(p.Supplier?.Name ?? "-")</td>
                            <td class="text-end fw-bold">@p.NetTotal.ToString("N2")</td>
                            <td class="text-center">
                                <a class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm"
                                   asp-action="CreateFromPurchase"
                                   asp-route-purchaseId="@p.Id">
                                    <i class="bi bi-check2-circle me-1"></i> اختيار
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/lib/datatables/css/dataTables.bootstrap.min.css" rel="stylesheet" />
    <style>
        .table > :not(caption) > * > * {
            padding: 1rem 0.6rem;
            color: #495057;
        }
        .dataTables_wrapper .dataTables_filter input {
            border-radius: 8px;
            padding: 8px 12px;
            border: 1px solid #dee2e6;
            margin-bottom: 20px;
        }
    </style>
}

@section Scripts {
    <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/datatables/js/dataTables.bootstrap.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#purchaseTable').DataTable({
                order: [[0, 'desc']],
                pageLength: 10,
                language: {
                    search: "_INPUT_",
                    searchPlaceholder: "ابحث عن الفاتورة أو المورد...",
                    lengthMenu: "عرض _MENU_ سجل",
                    info: "عرض _START_ إلى _END_ من إجمالي _TOTAL_ سجل",
                    infoEmpty: "تعرض 0 إلى 0 من أصل 0 سجل",
                    zeroRecords: "لم يتم العثور على فواتير مطابقة",
                    paginate: { first: "الأول", last: "الأخير", next: "التالي", previous: "السابق" }
                }
            });
        });
    </script>
}