@model PurchaseReturn
@{
    Layout = "~/Views/Shared/_InvoicePrintLayout.cshtml";
    ViewData["PrintPageTitle"] = $"مرتجع مشتريات #{Model.Id}";
    ViewData["PrintCloseUrl"] = Url.Action("Index", "PurchaseReturns");
}

<div class="container">
    <div class="header">
        <div class="company-info">
            <div class="company-name">شركة أبو أمن للأدوية</div>
            <div class="invoice-title">مرتجع مشتريات</div>
        </div>
        <div class="invoice-details">
            <div><strong>رقم المرتجع:</strong> #@Model.Id</div>
            <div><strong>فاتورة الشراء:</strong> #@Model.PurchaseId</div>
            <div><strong>التاريخ:</strong> @Model.ReturnDate.ToString("yyyy-MM-dd")</div>
        </div>
    </div>

    <div class="info-grid">
        <div class="info-item">
            <strong>المورد</strong>
            @Model.Supplier?.Name
        </div>
        <div class="info-item">
            <strong>رقم فاتورة المورد</strong>
            @(string.IsNullOrWhiteSpace(Model.Purchase?.InvoiceNo) ? "-" : Model.Purchase!.InvoiceNo)
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <div class="info-item" style="grid-column: span 2;">
                <strong>ملاحظات</strong>
                @Model.Notes
            </div>
        }
    </div>

    <table class="items-table">
        <thead>
            <tr>
                <th class="text-center" style="width: 50px;">#</th>
                <th>الصنف</th>
                <th style="width: 120px;">رقم الدفعة</th>
                <th style="width: 140px;">تاريخ الانتهاء</th>
                <th class="text-center" style="width: 90px;">الكمية</th>
                <th class="text-center" style="width: 100px;">سعر الشراء</th>
                <th class="text-center" style="width: 120px;">الإجمالي</th>
            </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
                foreach (var line in Model.Lines)
                {
                    <tr>
                        <td class="text-center">@(i++)</td>
                        <td>@line.Item?.NameAr</td>
                        <td class="text-center">@line.Batch?.BatchNo</td>
                        <td class="text-center">@((line.Batch != null) ? line.Batch.ExpiryDate.ToString("yyyy-MM-dd") : "-")</td>
                        <td class="text-center">@line.Qty.ToString("0.##")</td>
                        <td class="text-center">@line.UnitCost.ToString("N2")</td>
                        <td class="text-center">@line.LineTotal.ToString("N2")</td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <div class="totals-section">
        <table class="totals-table">
            <tr class="grand-total">
                <td class="label">إجمالي المرتجع</td>
                <td class="value">@Model.Total.ToString("N2")</td>
            </tr>
        </table>
    </div>

    <partial name="_InvoicePrintFooter" />
</div>
