@{
    ViewData["Title"] = "المبيعات";
}

<partial name="ERP_Components/_ERPRowActionsStyles" />

<div class="row justify-content-center">
    <div class="col-lg-12">
        <div class="d-flex justify-content-between align-items-center mb-3 mt-1">
            <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-cart3 me-2 text-primary"></i> إدارة المبيعات</h5>
            <div class="d-flex gap-2">
                <a class="btn btn-sm btn-outline-success px-3 rounded-pill shadow-sm d-flex align-items-center gap-2" asp-controller="CustomerReceipts" asp-action="Create">
                    <i class="bi bi-wallet2"></i> سند قبض
                </a>
                <a class="btn btn-sm btn-primary px-3 rounded-pill shadow-sm d-flex align-items-center gap-2" asp-action="Create">
                    <i class="bi bi-plus-lg"></i> إضافة فاتورة
                </a>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-3">
                <div class="table-responsive">
                    <table class="table table-hover align-middle text-center w-100" id="salesTable">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center">رقم الفاتورة</th>
                                <th class="text-center">العميل</th>
                                <th class="text-center">المندوب</th>
                                <th class="text-center">التاريخ</th>
                                <th class="text-center">الإجمالي</th>
                                <th class="text-center">الحالة</th>
                                <th class="text-center" style="width:120px;">العمليات</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/lib/datatables/css/datatables.bootstrap.min.css" rel="stylesheet" />
}

@section Scripts {
    <script src="~/lib/datatables/js/jquery.datatables.min.js"></script>
    <script src="~/lib/datatables/js/datatables.bootstrap.min.js"></script>

    <partial name="ERP_Components/_ERPDataTableScript" model='new AbuAmenPharma.ViewModels.ERPDataTableConfig { 
        TableId = "salesTable", 
        AjaxUrl = Url.Action("GetSalesData", "Sales"),
        ColumnsJson = "[{\"data\":\"id\",\"render\":function(data){return `<span class=\\\"fw-bold text-primary\\\">INV-${data}#</span>`;}},{\"data\":\"customerName\",\"render\":function(data){return `<span class=\\\"fw-bold text-dark\\\">${data||\"بدون عميل\"}</span>`;}},{\"data\":\"salesmanName\",\"defaultContent\":\"-\"},{\"data\":\"saleDate\",\"render\":function(data){if(!data)return \"-\";return new Date(data).toISOString().split(\"T\")[0];}},{\"data\":\"netTotal\",\"render\":function(data){return `<span class=\\\"fw-bold text-success\\\">${Number(data).toLocaleString(undefined,{minimumFractionDigits:2})}</span> <small class=\\\"text-muted\\\">جنيه سوداني</small>`;}},{\"data\":null,\"render\":function(row){if(row.remainingAmount<=0)return `<span class=\\\"badge rounded-pill bg-success px-3\\\">مدفوع</span>`;if(row.paidAmount>0)return `<span class=\\\"badge rounded-pill bg-warning text-dark px-3\\\">جزئي</span>`;return `<span class=\\\"badge rounded-pill bg-danger px-3\\\">آجل</span>`;}},{\"data\":\"id\",\"render\":function(data){return `<div class=\\\"row-actions\\\"><a href=\\\"/Sales/Details/${data}\\\" class=\\\"row-btn row-btn-view\\\" title=\\\"عرض\\\"><i class=\\\"bi bi-eye\\\"></i></a><a href=\\\"/Sales/Print/${data}\\\" target=\\\"_blank\\\" class=\\\"row-btn row-btn-print\\\" title=\\\"طباعة\\\"><i class=\\\"bi bi-printer\\\"></i></a></div>`;}}]",
        PageLength = 6
    }' />
}