@model Sale
@{
    Layout = "~/Views/Shared/_InvoicePrintLayout.cshtml";
    ViewData["PrintPageTitle"] = $"فاتورة بيع #{Model.Id}";
    ViewData["PrintCloseUrl"] = Url.Action("Index", "Sales");
    var allocations = ViewBag.Allocations as List<SaleAllocation> ?? new List<SaleAllocation>();
}

<div class="container">
    <div class="header d-flex justify-content-between align-items-start border-bottom mb-4 pb-3">
        <div class="header-right">
            <div class="company-name">شركة أبو آمن للأدوية</div>
            <div class="invoice-title-badge">فاتورة بيع</div>
            
            <div class="info-summary-grid">
                <div class="summary-item">
                    <span class="label">رقم الفاتورة:</span>
                    <span class="value">#@Model.Id</span>
                </div>
                <div class="summary-item">
                    <span class="label">التاريخ:</span>
                    <span class="value">@Model.SaleDate.ToString("yyyy-MM-dd")</span>
                </div>
            </div>
        </div>
        <div class="header-left d-flex align-items-center justify-content-center" style="width: 150px; height: 120px;">
            <img src="@Url.Content("~/img/abuamen-mark.svg")" style="width: 100%; height: 100%; object-fit: contain; display: block;" alt="شعار أبو آمن" />
        </div>
    </div>

    <div class="info-grid">
        <div class="info-item">
            <strong>العميل</strong>
            @Model.Customer?.Name
        </div>
        <div class="info-item">
            <strong>نوع الدفع</strong>
            @(Model.PaymentMode == SalePaymentMode.Cash ? "نقدي" : "آجل")
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <div class="info-item" style="grid-column: span 2;">
                <strong>ملاحظات</strong>
                @Model.Notes
            </div>
        }
    </div>

    <table class="items-table">
        <thead>
            <tr>
                <th class="text-center" style="width: 50px;">#</th>
                <th>الصنف</th>
                <th style="width: 220px;">الدفعات</th>
                <th style="width: 220px;">تاريخ الانتهاء</th>
                <th class="text-center" style="width: 80px;">الكمية</th>
                <th class="text-center" style="width: 100px;">السعر</th>
                <th class="text-center" style="width: 120px;">الإجمالي</th>
            </tr>
        </thead>
        <tbody>
            @{
                int count = 1;
                foreach (var line in Model.Lines)
                {
                    var lineAllocs = allocations.Where(x => x.SaleLineId == line.Id).ToList();
                    <tr>
                        <td class="text-center">@(count++)</td>
                        <td>@line.Item?.NameAr</td>
                        <td>
                            @if (lineAllocs.Count == 0)
                            {
                                <span class="muted">-</span>
                            }
                            else
                            {
                                <div class="line-list">
                                    @foreach (var a in lineAllocs)
                                    {
                                        <div>@a.Batch?.BatchNo</div>
                                    }
                                </div>
                            }
                        </td>
                        <td>
                            @if (lineAllocs.Count == 0)
                            {
                                <span class="muted">-</span>
                            }
                            else
                            {
                                <div class="line-list">
                                    @foreach (var a in lineAllocs)
                                    {
                                        <div>@(a.Batch != null ? a.Batch.ExpiryDate.ToString("yyyy-MM-dd") : "-")</div>
                                    }
                                </div>
                            }
                        </td>
                        <td class="text-center">@line.Qty.ToString("N0")</td>
                        <td class="text-center">@line.UnitPrice.ToString("N2")</td>
                        <td class="text-center">@line.LineTotal.ToString("N2")</td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <div class="totals-section">
        <table class="totals-table">
            <tr>
                <td class="label">الإجمالي</td>
                <td class="value">@Model.SubTotal.ToString("N2")</td>
            </tr>
            @if (Model.Discount > 0)
            {
                <tr>
                    <td class="label">الخصم</td>
                    <td class="value">- @Model.Discount.ToString("N2")</td>
                </tr>
            }
            <tr class="grand-total">
                <td class="label">الصافي النهائي</td>
                <td class="value">@Model.NetTotal.ToString("N2")</td>
            </tr>
            @if (Model.RemainingAmount > 0 && Model.PaymentMode == SalePaymentMode.Credit)
            {
                <tr>
                    <td class="label">المتبقي المطلوب</td>
                    <td class="value">@Model.RemainingAmount.ToString("N2")</td>
                </tr>
            }
        </table>
    </div>

    <partial name="_InvoicePrintFooter" />
</div>
