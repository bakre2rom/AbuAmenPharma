@model Sale
@using System.Globalization
@{
    ViewData["Title"] = "تفاصيل فاتورة بيع";
    var allocations = ViewBag.Allocations as List<SaleAllocation> ?? new List<SaleAllocation>();
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-1">
    <div>
        <h4 class="mb-0 fw-bold text-dark"><i class="bi bi-receipt me-2 text-primary"></i> تفاصيل فاتورة بيع #@Model.Id</h4>
        <div class="text-muted small mt-1">
            <span class="me-2">العميل: <strong class="text-dark">@Model.Customer?.Name</strong></span> |
            <span class="mx-2">المندوب: <strong class="text-dark">@Model.Salesman?.NameAr</strong></span> |
            <span class="mx-2">التاريخ: <strong class="text-dark">@Model.SaleDate.ToString("yyyy-MM-dd")</strong></span> |
            <span class="ms-2">نوع الدفع: <strong class="text-dark">@(Model.PaymentMode == SalePaymentMode.Cash ? "نقدي" : "آجل")</strong></span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-sm btn-outline-secondary px-3 rounded-pill" asp-action="Index">
            <i class="bi bi-arrow-right me-1"></i> رجوع
        </a>
        <a class="btn btn-sm btn-success px-3 rounded-pill shadow-sm" target="_blank" asp-action="Print" asp-route-id="@Model.Id">
            <i class="bi bi-printer me-1"></i> طباعة
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-5">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-0">
                <table class="table table-sm table-borderless mb-0">
                    <tr class="border-bottom">
                        <td class="p-2 ps-3 text-muted">إجمالي البنود</td>
                        <td class="p-2 pe-3 text-end fw-bold">@Model.SubTotal.ToString("N2")</td>
                    </tr>
                    <tr class="border-bottom">
                        <td class="p-2 ps-3 text-muted">الخصم</td>
                        <td class="p-2 pe-3 text-end text-danger fw-bold">- @Model.Discount.ToString("N2")</td>
                    </tr>
                    <tr class="bg-light">
                        <td class="p-2 ps-3 fw-bold text-primary">الصافي النهائي</td>
                        <td class="p-2 pe-3 text-end fw-bold text-primary" style="font-size: 1.1rem;">@Model.NetTotal.ToString("N2")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
        <div class="col-md-7">
            <div class="card shadow-sm border-0 h-100 rounded-3">
                <div class="card-body">
                    <h6 class="fw-bold text-muted mb-2 small"><i class="bi bi-sticky me-1"></i> ملاحظات الفاتورة</h6>
                    <p class="mb-0 text-dark">@Model.Notes</p>
                </div>
            </div>
        </div>
    }
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white border-0 py-3">
        <h6 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2"></i> بنود الفاتورة</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-3">الصنف</th>
                        <th class="text-center">الكمية</th>
                        <th class="text-center">السعر</th>
                        <th class="text-center">الإجمالي</th>
                        <th class="pe-3">توزيع الباتشات (FIFO)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in Model.Lines)
                    {
                        var lineAllocs = allocations.Where(a => a.SaleLineId == line.Id).ToList();
                        <tr>
                            <td class="ps-3"><span class="fw-bold text-dark">@line.Item?.NameAr</span></td>
                            <td class="text-center">@line.Qty.ToString("N0")</td>
                            <td class="text-center">@line.UnitPrice.ToString("N2")</td>
                            <td class="text-center fw-bold">@line.LineTotal.ToString("N2")</td>
                            <td class="pe-3">
                                @if (lineAllocs.Count == 0)
                                {
                                    <span class="text-muted small">تلقائي</span>
                                }
                                else
                                {
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var a in lineAllocs)
                                        {
                                            <span class="badge bg-light text-dark border fw-normal py-1 px-2">
                                                <i class="bi bi-box-seam me-1 text-muted"></i> @a.Batch?.BatchNo
                                                <small class="text-muted ms-1">(@a.Qty)</small>
                                            </span>
                                        }
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
