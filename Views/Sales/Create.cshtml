@using AbuAmenPharma.ViewModels
@model SaleCreateVM
@{
    ViewData["Title"] = "فاتورة بيع";
}

<form asp-action="Create" method="post" id="saleForm">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger mb-2"></div>
    <input type="hidden" name="UseCustomerCredit" value="false" />
    <input type="hidden" name="CustomerCreditUsed" value="0" />

    <div class="row g-3" style="min-height: calc(100vh - 120px);">

        <!-- ===== RIGHT PANEL: Invoice Lines (appears right in RTL) ===== -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 pt-3 pb-2 px-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-receipt-cutoff me-1 text-primary"></i>بنود الفاتورة</h5>
                    <button type="button" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm" id="addRowBtn">
                        <i class="bi bi-plus-lg me-1"></i>إضافة بند
                    </button>
                </div>
                <div class="card-body p-2 pt-0">
                    <div class="table-responsive" style="max-height: calc(100vh - 280px); overflow-y: auto;">
                        <table class="table table-sm table-hover align-middle mb-0" id="linesTable">
                            <thead class="table-light" style="position: sticky; top: 0; z-index: 2;">
                                <tr>
                                    <th style="width:35%; min-width:200px;">الصنف</th>
                                    <th style="width:12%;" class="text-center">المتاح</th>
                                    <th style="width:13%;" class="text-center">الكمية</th>
                                    <th style="width:15%;" class="text-center">السعر</th>
                                    <th style="width:15%;" class="text-center">الإجمالي</th>
                                    <th style="width:10%;" class="text-center"></th>
                                </tr>
                            </thead>
                            <tbody id="linesTableBody">
                                <!-- rows added dynamically -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== LEFT PANEL: Sidebar (appears left in RTL) ===== -->
        <div class="col-lg-4">
            <div class="position-lg-sticky" style="top: 80px;">

                <!-- Merged Sidebar Card -->
                <div class="card border-0 shadow-sm rounded-4 mb-2">
                    <div class="card-header bg-primary bg-gradient text-white border-0 rounded-top-4 py-2 px-3">
                        <h6 class="mb-0 fw-bold small"><i class="bi bi-receipt me-2"></i>ملخص الفاتورة</h6>
                    </div>
                    <div class="card-body p-2 mt-n1">
                        <div class="row g-1 mb-2">
                            <div class="col-6">
                                <label class="form-label tiny-label fw-semibold mb-0">التاريخ</label>
                                <input asp-for="SaleDate" class="form-control form-control-sm rounded-2 bg-light py-0" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" />
                            </div>
                            <div class="col-12">
                                <label class="form-label tiny-label fw-semibold mb-0">العميل</label>
                                <div class="d-flex gap-1">
                                    <select asp-for="CustomerId" class="form-control form-control-sm rounded-2" id="customerSelect" style="width:100%"></select>
                                    <button type="button" class="btn btn-sm btn-primary px-2" data-bs-toggle="modal" data-bs-target="#createCustomerModal"><i class="bi bi-plus-lg"></i></button>
                                </div>
                                <div class="form-text mt-1">سيتم اعتماد مندوب العميل تلقائياً من بيانات العميل.</div>
                            </div>
                            <div class="col-6">
                                <label class="form-label tiny-label fw-semibold mb-0">الخصم</label>
                                <input asp-for="Discount" class="form-control form-control-sm rounded-2" id="discount" type="number" step="0.01" value="0" />
                            </div>
                             <div class="col-6 text-end align-self-end">
                                <div class="text-muted tiny-label mb-0">المتبقي</div>
                                <div class="fw-bold text-danger fs-6" id="remainingLabel" style="line-height:1">0.00</div>
                            </div>
                        </div>

                        <hr class="my-1 opacity-25">

                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="text-muted small">الإجمالي:</span>
                            <span id="subTotalLabel" class="small fw-semibold">0.00</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="text-muted small">الخصم:</span>
                            <span id="discountLabel" class="small text-danger fw-semibold">0.00</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center pt-1 border-top">
                            <span class="fw-bold">الصافي:</span>
                            <span id="netTotalLabel" class="fw-bold text-primary fs-6 mb-0">0.00</span>
                        </div>
                    </div>
                </div>

                <input type="hidden" asp-for="PaidAmount" value="0" id="paidAmount" />
                <input type="hidden" asp-for="Notes" value="" />
                <input type="hidden" asp-for="PaymentMode" value="Credit" id="paymentMode" />

                <!-- Action Buttons: Side by side -->
                <div class="row g-2">
                    <div class="col-8">
                        <button class="btn btn-success w-100 shadow-sm rounded-3 py-2 fw-bold" type="submit">
                            <i class="bi bi-check-lg me-1"></i>حفظ وترحيل
                        </button>
                    </div>
                    <div class="col-4">
                        <a class="btn btn-outline-secondary w-100 rounded-3 py-2" asp-action="Index">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    </div>
                </div>

            </div>
        </div>

    </div>
</form>

<!-- Create Customer Modal -->
<div class="modal fade" id="createCustomerModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title">إضافة عميل جديد</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-4">
                    <label class="form-label fw-semibold">اسم العميل <span class="text-danger">*</span></label>
                    <input type="text" id="newCustomerName" class="form-control bg-light" placeholder="اسم العميل..." required />
                </div>

            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary px-4 shadow-sm" id="saveCustomerBtn">حفظ</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/lib/select2/css/select2.min.css" rel="stylesheet" />
    <style>
        .select2-container--default .select2-selection--single {
            height: 31px;
            border: 1px solid #ced4da;
            border-radius: 6px;
            font-size: 0.875rem;
        }
        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 29px;
            font-size: 0.875rem;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 29px;
        }
        .select2-dropdown {
            z-index: 99999;
        }
        .available-quantity {
            background-color: #e8f5e9;
            text-align: center;
            font-weight: bold;
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 0.85rem;
            color: #2e7d32;
        }
        #linesTable th {
            font-size: 0.8rem;
            font-weight: 600;
            white-space: nowrap;
        }
        #linesTable td {
            vertical-align: middle;
            padding: 0.35rem 0.4rem;
        }
        #linesTable .form-control-sm {
            font-size: 0.85rem;
        }
        .rowTotal {
            font-weight: bold;
            color: #198754;
        }

        /* Sticky sidebar on large screens */
        @@media (min-width: 992px) {
            .position-lg-sticky {
                position: sticky !important;
                top: 80px;
            }
        }
        .tiny-label {
            font-size: 0.75rem;
            color: #6c757d;
        }
    </style>
}

@section Scripts {
    <script src="~/lib/select2/js/select2.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        let rowCounter = 0;
        let customerAvailableCredit = 0;
        const stockCache = {};

        // Save Customer via AJAX
        $(document).ready(function() {
            $('#saveCustomerBtn').click(function () {
                var cName = $('#newCustomerName').val();
                if (!cName) {
                    Swal.fire('خطأ', 'يرجى إدخال اسم العميل', 'error');
                    return;
                }

                $.post('@Url.Action("CreateCustomerAjax", "Sales")', { name: cName }, function (res) {
                    if (res && res.id) {
                        var newOption = new Option(res.text, res.id, true, true);
                        $('#customerSelect').append(newOption).trigger('change');
                        $('#createCustomerModal').modal('hide');
                        $('#newCustomerName').val('');
                        Swal.fire({
                            icon: 'success',
                            title: 'نجاح',
                            text: 'تمت إضافة العميل بنجاح',
                            timer: 2000,
                            showConfirmButton: false
                        });
                    } else {
                        Swal.fire('خطأ', 'حدث خطأ غير متوقع', 'error');
                    }
                }).fail(function (xhr) {
                    Swal.fire('خطأ', xhr.responseText || 'تعذر الاتصال بالخادم', 'error');
                });
            });
        });

        function parseNumber(value) {
            if (!value) return 0;
            return parseFloat(value.toString().replace(/[^\d.-]/g, '')) || 0;
        }

        function formatMoney(value) {
            return parseNumber(value).toFixed(2);
        }

        function getRowItemId($row) {
            const raw = $row.find('.itemSelect').val();
            const id = parseInt(raw, 10);
            return Number.isNaN(id) ? 0 : id;
        }

        function getRowQty($row) {
            return parseNumber($row.find('.qtyInput').val());
        }

        function updateStockDisplayForAllRows() {
            const requestedByItem = {};

            $('#linesTableBody tr').each(function () {
                const $row = $(this);
                const itemId = getRowItemId($row);
                if (!itemId) return;

                const qty = getRowQty($row);
                requestedByItem[itemId] = (requestedByItem[itemId] || 0) + qty;
            });

            $('#linesTableBody tr').each(function () {
                const $row = $(this);
                const itemId = getRowItemId($row);
                if (!itemId) {
                    $row.data('availableForRow', 0);
                    $row.find('.availableQuantity').html('<span class="text-muted">-</span>');
                    return;
                }

                const info = stockCache[itemId] || { totalAvailable: 0, detailsHtml: '' };
                const rowQty = getRowQty($row);
                const usedInOtherRows = (requestedByItem[itemId] || 0) - rowQty;
                const availableForRow = info.totalAvailable - usedInOtherRows;
                const safeAvailable = Math.max(0, availableForRow);

                $row.data('availableForRow', availableForRow);
                $row.find('.availableQuantity').html(`
                    <div class="available-quantity" title="${(info.detailsHtml || '').replace(/"/g, '&quot;')}">
                        ${formatMoney(safeAvailable)}
                    </div>
                `);
            });
        }





        // تهيئة Select2 للعملاء
        function initCustomerSelect2() {
            $('#customerSelect').select2({
                placeholder: 'اختر عميل...',
                allowClear: true,
                dir: 'rtl',
                ajax: {
                    url: '@Url.Action("SearchCustomers", "Sales")',
                    dataType: 'json',
                    delay: 250,
                    data: function(params) {
                        return { term: params.term };
                    },
                    processResults: function(data) {
                        return { results: data };
                    }
                }
            });
        }

        // تهيئة Select2 للعناصر
        function initItemSelect2(selector) {
            $(selector).select2({
                placeholder: 'اختر صنف...',
                allowClear: true,
                dir: 'rtl',
                ajax: {
                    url: '@Url.Action("SearchItems", "Sales")',
                    dataType: 'json',
                    delay: 250,
                    data: function(params) {
                        return { term: params.term };
                    },
                    processResults: function(data) {
                        return { results: data };
                    }
                }
            }).on('select2:select', function(e) {
                const $row = $(this).closest('tr');
                const itemId = e.params.data.id;

                $row.find('.availableQuantity').html('<span class="spinner-border spinner-border-sm"></span>');

                $.get('@Url.Action("GetItemAvailability", "Sales")', { id: itemId }, function(res) {
                    let totalAvailable = 0;
                    let detailsHtml = '';

                    if (res && res.batches && res.batches.length > 0) {
                        totalAvailable = res.totalAvailable || 0;
                        detailsHtml = '<div class="small text-muted">';
                        res.batches.forEach(function(b) {
                            detailsHtml += '<div>';
                            detailsHtml += '<span class="badge bg-info">' + (b.batchNo || 'بدون دفعة') + '</span>';
                            detailsHtml += '<span class="mx-1">' + formatMoney(b.balance) + '</span>';
                            if (b.expiry) {
                                detailsHtml += '<span class="text-secondary"> (' + b.expiry + ')</span>';
                            }
                            detailsHtml += '</div>';
                        });
                        detailsHtml += '</div>';
                    }

                    stockCache[itemId] = {
                        totalAvailable: parseNumber(totalAvailable),
                        detailsHtml: detailsHtml
                    };
                    updateStockDisplayForAllRows();
                    calculateTotals();

                    $.get('@Url.Action("GetItemPrice", "Sales")', { id: itemId }, function(priceRes) {
                        if (priceRes && priceRes.price) {
                            $row.find('.priceInput').val(formatMoney(priceRes.price));
                            calculateRowTotal($row);
                            updateStockDisplayForAllRows();
                            calculateTotals();
                        }
                    });
                });
            }).on('select2:clear', function () {
                updateStockDisplayForAllRows();
                calculateTotals();
            });
        }

        // إنشاء صف جديد
        function createNewRow() {
            const rowId = rowCounter++;
            const html = `
                <tr data-row="${rowId}">
                    <td>
                        <input type="hidden" name="Lines.Index" value="${rowId}" />
                        <select name="Lines[${rowId}].ItemId" class="form-control form-control-sm itemSelect" style="width:100%"></select>
                    </td>
                    <td class="availableQuantity text-center align-middle">
                        <span class="text-muted">-</span>
                    </td>
                    <td>
                        <input type="number" name="Lines[${rowId}].Qty" class="form-control form-control-sm qtyInput text-center" step="0.01" min="0" value="0" />
                    </td>
                    <td>
                        <input type="number" name="Lines[${rowId}].UnitPrice" class="form-control form-control-sm priceInput text-center" step="0.01" min="0" value="0" />
                    </td>
                    <td class="text-center align-middle">
                        <span class="rowTotal">0.00</span>
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-outline-danger removeRow" style="width:28px;height:28px;padding:0;line-height:28px;">
                            <i class="bi bi-x"></i>
                        </button>
                    </td>
                </tr>
            `;

            $('#linesTableBody').append(html);
            initItemSelect2(`#linesTableBody tr:last .itemSelect`);
        }

        // حساب إجمالي الصف
        function calculateRowTotal($row) {
            const qty = parseNumber($row.find('.qtyInput').val());
            const price = parseNumber($row.find('.priceInput').val());
            const total = qty * price;
            $row.find('.rowTotal').text(formatMoney(total));
            return total;
        }

        // التحقق من الكمية
        function validateQuantity($row) {
            const qty = parseNumber($row.find('.qtyInput').val());
            const available = parseNumber($row.data('availableForRow'));

            if (available > 0 && qty > available) {
                $row.find('.qtyInput').addClass('is-invalid');
                return false;
            } else if (available <= 0 && qty > 0 && getRowItemId($row) > 0) {
                $row.find('.qtyInput').addClass('is-invalid');
                return false;
            } else {
                $row.find('.qtyInput').removeClass('is-invalid');
                return true;
            }
        }

        // حساب الإجماليات الكلية
        function calculateTotals() {
            let subtotal = 0;
            let hasErrors = false;
            updateStockDisplayForAllRows();

            $('#linesTableBody tr').each(function() {
                const $row = $(this);
                subtotal += parseNumber($row.find('.rowTotal').text());

                if (!validateQuantity($row)) {
                    hasErrors = true;
                }
            });

            const discount = parseNumber($('#discount').val());
            const netTotal = Math.max(0, subtotal - discount);
            const maxCashCanPay = netTotal;

            // Only calculate net and remaining based on total and discount
            $('#subTotalLabel').text(formatMoney(subtotal));
            $('#discountLabel').text(formatMoney(discount));
            $('#netTotalLabel').text(formatMoney(netTotal));
            $('#remainingLabel').text(formatMoney(netTotal));

            if (hasErrors) {
                $('#saleForm button[type="submit"]').prop('disabled', true);
            } else {
                $('#saleForm button[type="submit"]').prop('disabled', false);
            }
        }

        // إعادة ترقيم الصفوف بعد الحذف
        function reindexRows() {
            let index = 0;
            $('#linesTableBody tr').each(function() {
                const $row = $(this);
                $row.attr('data-row', index);
                $row.find('input[name="Lines.Index"]').val(index);
                $row.find('.itemSelect').attr('name', `Lines[${index}].ItemId`);
                $row.find('.qtyInput').attr('name', `Lines[${index}].Qty`);
                $row.find('.priceInput').attr('name', `Lines[${index}].UnitPrice`);
                index++;
            });
            rowCounter = index;
        }

        // أحداث الصفحة
        $(document).ready(function() {
            initCustomerSelect2();
            $('#customerSelect').on('change', function () {
                calculateTotals();
            });

            // إضافة أول صف
            createNewRow();

            // زر إضافة صف
            $('#addRowBtn').click(function() {
                createNewRow();
            });

            // حذف صف
            $('#linesTable').on('click', '.removeRow', function() {
                if ($('#linesTableBody tr').length > 1) {
                    const $select = $(this).closest('tr').find('.itemSelect');
                    if ($select.data('select2')) {
                        $select.select2('destroy');
                    }
                    $(this).closest('tr').remove();
                    reindexRows();
                    updateStockDisplayForAllRows();
                    calculateTotals();
                } else {
                    Swal.fire('تنبيه', 'لا يمكن حذف كل البنود، يجب وجود بند واحد على الأقل', 'warning');
                }
            });

            // حساب عند تغيير الكمية أو السعر
            $('#linesTable').on('input', '.qtyInput, .priceInput', function() {
                const $row = $(this).closest('tr');
                calculateRowTotal($row);
                validateQuantity($row);
                calculateTotals();
            });

            // تغيير الخصم
            $('#discount').on('input', function() {
                calculateTotals();
            });

            // تغيير المدفوع
            $('#paidAmount').on('input', function() {
                calculateTotals();
            });

            // حساب أولي
            calculateTotals();

            // قبل إرسال النموذج
            $('#saleForm').submit(function(e) {
                if ($('#linesTableBody tr').length === 0) {
                    e.preventDefault();
                    Swal.fire('خطأ', 'يجب إضافة بند واحد على الأقل', 'error');
                    return false;
                }

                let hasError = false;
                $('#linesTableBody tr').each(function() {
                    const $row = $(this);
                    if (!$row.find('.itemSelect').val()) {
                        hasError = true;
                        Swal.fire('خطأ', 'يجب اختيار صنف لكل بند', 'error');
                        e.preventDefault();
                        return false;
                    }

                    if (!validateQuantity($row)) {
                        hasError = true;
                        Swal.fire('خطأ', 'الكمية المدخلة أكبر من الكمية المتاحة', 'error');
                        e.preventDefault();
                        return false;
                    }
                });

                if (hasError) {
                    return false;
                }

                $('#discount').val(formatMoney($('#discount').val()));

                $('#linesTableBody tr').each(function() {
                    const $row = $(this);
                    $row.find('.qtyInput').val(parseNumber($row.find('.qtyInput').val()));
                    $row.find('.priceInput').val(parseNumber($row.find('.priceInput').val()));
                });
            });
        });
    </script>
}
