@model List<Microsoft.AspNetCore.Identity.IdentityUser>
@{
    ViewData["Title"] = "إدارة المستخدمين";
}

<partial name="ERP_Components/_ERPRowActionsStyles" />

<div class="row justify-content-center">
    <div class="col-lg-12">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4 mt-1">
            <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-shield-lock me-2 text-primary"></i> إدارة مستخدمي النظام</h5>
            <div class="d-flex gap-2">
                <a class="btn btn-sm btn-primary px-3 rounded-pill shadow-sm d-flex align-items-center gap-2" asp-action="Create">
                    <i class="bi bi-person-plus"></i> مستخدم جديد
                </a>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success py-2 px-3 small border-0 shadow-sm rounded-3 mb-3">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger py-2 px-3 small border-0 shadow-sm rounded-3 mb-3">@TempData["ErrorMessage"]</div>
        }

        <!-- Card Container -->
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-3">
                <div class="table-responsive">
                    <table class="table table-hover align-middle w-100" id="usersTable">
                        <thead class="table-light">
                            <tr>
                                <th>البريد الإلكتروني / اسم المستخدم</th>
                                <th>الحالة</th>
                                <th class="text-center" style="width:200px;">العمليات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in Model)
                            {
                                var isLocked = u.LockoutEnd.HasValue && u.LockoutEnd.Value > DateTimeOffset.UtcNow;
                                <tr>
                                    <td><span class="fw-bold text-dark">@u.Email</span></td>
                                    <td>
                                        @if (isLocked)
                                        {
                                            <span class="badge rounded-pill bg-danger px-3">معطل</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-success px-3">نشط</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="row-actions justify-content-center">
                                            <!-- Password Reset -->
                                            <button type="button" class="row-btn row-btn-view reset-pass-btn" 
                                                    data-bs-toggle="modal" data-bs-target="#resetPasswordModal"
                                                    data-id="@u.Id" data-email="@u.Email" title="تغيير كلمة المرور">
                                                <i class="bi bi-key"></i>
                                            </button>

                                            <!-- Toggle Lock -->
                                            <form asp-action="ToggleLock" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@u.Id" />
                                                @if (isLocked)
                                                {
                                                    <button type="submit" class="row-btn row-btn-print" title="تفعيل المستخدم"><i class="bi bi-unlock"></i></button>
                                                }
                                                else
                                                {
                                                    <button type="submit" class="row-btn row-btn-delete" title="تعطيل المستخدم"><i class="bi bi-lock"></i></button>
                                                }
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Password Reset Modal -->
<div class="modal fade" id="resetPasswordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title fw-bold">إعادة تعيين كلمة المرور</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ChangePassword" method="post" id="resetPasswordForm">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4 bg-white">
                    <input type="hidden" id="resetUserId" name="id" />
                    <p class="mb-3 text-muted small">تغيير كلمة المرور للمستخدم: <strong id="resetUserEmail" class="text-dark"></strong></p>
                    
                    <partial name="ERP_Components/_ERPLabeledInput" model='new AbuAmenPharma.ViewModels.ERPLabeledInputVM { Label = "كلمة المرور الجديدة", Name = "newPassword", Type = "password", Required = true }' />
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm fw-bold">حفظ الدخول الجديد</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.reset-pass-btn').on('click', function() {
                const btn = $(this);
                $('#resetUserId').val(btn.data('id'));
                $('#resetUserEmail').text(btn.data('email'));
            });
        });
    </script>
}