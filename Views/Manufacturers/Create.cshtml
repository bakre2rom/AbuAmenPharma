@model Manufacturer
@{
    ViewData["Title"] = "إضافة شركة";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 rounded-3 mt-3">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h3 class="mb-0 text-primary">إضافة شركة</h3>
                <p class="text-muted small">يرجى ملء البيانات التالية لإضافة شركة جديدة إلى النظام</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">اسم الشركة <span class="text-danger">*</span></label>
                        <input asp-for="NameAr" class="form-control bg-light" placeholder="مثال: شركة الأدوية الحديثة" />
                        <span asp-validation-for="NameAr" class="text-danger small"></span>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input class="form-check-input" type="checkbox" role="switch" id="isActiveSwitch" asp-for="IsActive" checked>
                        <label class="form-check-label fw-semibold ms-2" for="isActiveSwitch">تفعيل الشركة</label>
                    </div>

                    <div class="d-flex justify-content-end gap-2 pt-2 border-top">
                        <a class="btn btn-outline-secondary px-4" asp-action="Index">إلغاء</a>
                        <button type="submit" class="btn btn-primary px-4 shadow-sm">حفظ البيانات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}