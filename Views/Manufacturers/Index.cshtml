@model IEnumerable<Manufacturer>
@{
    ViewData["Title"] = "إدارة الشركات";
}

<div class="row justify-content-center">
    <div class="col-lg-12">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-2 mt-1">
            <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-building me-1"></i> إدارة الشركات</h5>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-sm btn-primary px-3 rounded-pill shadow-sm d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#createManufacturerModal">
                    <i class="bi bi-plus-lg"></i> إضافة شركة
                </button>
            </div>
        </div>

        <!-- Card Container -->
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-3">
                <div class="table-responsive">
                    <table class="table table-hover align-middle w-100" id="manufacturersTable" style="margin-top: 15px;">
                        <thead class="table-light text-muted">
                            <tr>
                                <th class="fw-semibold pb-3">اسم الشركة</th>
                                <th class="fw-semibold pb-3 text-center" style="width:180px;">العمليات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in Model)
                            {
                                <tr>
                                    <td><span class="fw-bold text-dark">@u.NameAr</span></td>
                                    <td>
                                        <div class="d-flex justify-content-center gap-2">
                                            <button type="button"
                                                    class="btn btn-outline-secondary floating-action-btn edit-manufacturer-btn"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editManufacturerModal"
                                                    data-id="@u.Id"
                                                    data-namear="@u.NameAr"
                                                    data-country="@u.Country"
                                                    title="تعديل">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button type="button"
                                                    class="btn btn-outline-danger floating-action-btn disable-manufacturer-btn"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#disableManufacturerModal"
                                                    data-id="@u.Id"
                                                    data-namear="@u.NameAr"
                                                    title="تعطيل">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createManufacturerModal" tabindex="-1" aria-labelledby="createManufacturerModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title" id="createManufacturerModalLabel">إضافة شركة جديدة</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body p-4">
                    <div class="mb-4">
                        <label class="form-label fw-semibold">اسم الشركة <span class="text-danger">*</span></label>
                        <input name="NameAr" class="form-control bg-light" placeholder="مثال: شركة الأدوية الحديثة" required oninvalid="this.setCustomValidity('حقل الاسم مطلوب')" oninput="this.setCustomValidity('')" />
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm">حفظ</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editManufacturerModal" tabindex="-1" aria-labelledby="editManufacturerModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-secondary text-white border-0">
                <h5 class="modal-title" id="editManufacturerModalLabel">تعديل شركة</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <input type="hidden" id="editManufacturerId" name="Id" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">اسم الشركة <span class="text-danger">*</span></label>
                        <input id="editManufacturerNameAr" name="NameAr" class="form-control bg-light" required />
                    </div>
                    <div>
                        <label class="form-label fw-semibold">الدولة</label>
                        <input id="editManufacturerCountry" name="Country" class="form-control bg-light" />
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-secondary px-4 shadow-sm">حفظ التعديلات</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Disable Modal -->
<div class="modal fade" id="disableManufacturerModal" tabindex="-1" aria-labelledby="disableManufacturerModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white border-0">
                <h5 class="modal-title" id="disableManufacturerModalLabel">تعطيل شركة</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Disable" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <input type="hidden" id="disableManufacturerId" name="Id" />
                    <p class="mb-0">هل أنت متأكد من تعطيل الشركة: <strong id="disableManufacturerName"></strong> ؟</p>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-danger px-4 shadow-sm">تعطيل</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/lib/datatables/css/dataTables.bootstrap.min.css" rel="stylesheet" />
    <style>
        .table > :not(caption) > * > * {
            padding: 1rem 0.5rem;
            color: #495057;
        }
        .dataTables_wrapper .dataTables_filter input {
            border-radius: 8px;
            padding: 8px;
            border: 1px solid #dee2e6;
            margin-bottom: 15px;
        }
        table.dataTable.table-striped > tbody > tr.odd > * {
            box-shadow: none;
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/datatables/js/dataTables.bootstrap.min.js"></script>

    <script>
        $(document).ready(function() {
            $('#manufacturersTable').DataTable({
                order: [[0, 'asc']],
                pageLength: 5,
                language: {
                    search: "_INPUT_",
                    searchPlaceholder: "ابحث عن أي شيء هنا...",
                    lengthMenu: "عرض _MENU_ سجل",
                    info: "عرض _START_ إلى _END_ من إجمالي _TOTAL_ سجل",
                    infoEmpty: "تعرض 0 إلى 0 من أصل 0 سجل",
                    zeroRecords: "لم يتم العثور على سجلات متطابقة",
                    paginate: { first: "الأول", last: "الأخير", next: "التالي", previous: "السابق" }
                }
            });

            $('.edit-manufacturer-btn').on('click', function () {
                const btn = $(this);
                $('#editManufacturerId').val(btn.data('id'));
                $('#editManufacturerNameAr').val(btn.data('namear'));
                $('#editManufacturerCountry').val(btn.data('country'));
            });

            $('.disable-manufacturer-btn').on('click', function () {
                const btn = $(this);
                $('#disableManufacturerId').val(btn.data('id'));
                $('#disableManufacturerName').text(btn.data('namear'));
            });
        });
    </script>
}
