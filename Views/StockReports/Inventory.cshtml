@using AbuAmenPharma.ViewModels
@model List<InventoryStocktakeVM>
@{
    ViewData["Title"] = "تقرير جرد المخزن";
    int days = (int)(ViewBag.Days ?? 90);
    var q = (string)(ViewBag.Q ?? "");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">تقرير جرد المخزن</h3>
    <a class="btn btn-outline-secondary" onclick="window.print()">طباعة</a>
</div>

<form method="get" class="card p-3 mb-3">
    <div class="row">
        <div class="col-md-3">
            <label class="form-label">قريب خلال (يوم)</label>
            <input name="days" type="number" class="form-control" value="@days" min="1" />
        </div>
        <div class="col-md-6">
            <label class="form-label">بحث (اسم الدواء / رقم الدفعة)</label>
            <input name="q" class="form-control" value="@q" />
        </div>
        <div class="col-md-3 d-flex align-items-end gap-2">
            <button class="btn btn-primary w-100">عرض</button>
            <a class="btn btn-outline-secondary w-100" asp-action="Inventory">مسح</a>
        </div>
    </div>
</form>

<table class="table table-striped table-bordered align-middle">
    <thead>
        <tr>
            <th>الدواء</th>
            <th class="text-center">رقم الدفعة</th>
            <th class="text-center">تاريخ الانتهاء</th>
            <th class="text-end">الكمية المتوفرة</th>
            <th class="text-center">الحالة</th>
            <th class="text-center">أيام للانتهاء</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center text-muted p-4">لا توجد أصناف برصيد.</td>
            </tr>
        }
        else
        {
            foreach (var x in Model)
            {
                var rowClass = x.Status == "منتهي" ? "table-danger"
                : x.Status == "قريب" ? "table-warning"
                : "";

                <tr class="@rowClass">
                    <td>@x.ItemName</td>
                    <td class="text-center">@x.BatchNo</td>
                    <td class="text-center">@x.ExpiryDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-end"><strong>@x.Balance</strong></td>
                    <td class="text-center">@x.Status</td>
                    <td class="text-center">@x.DaysToExpiry</td>
                </tr>
            }
        }
    </tbody>

    <tfoot class="table-dark">
        <tr>
            <th colspan="3">الإجمالي</th>
            <th class="text-end">@Model.Sum(x => x.Balance)</th>
            <th colspan="2"></th>
        </tr>
    </tfoot>
</table>

<style>
    @@media print {
        form, .btn

    {
        display: none !important;
    }

    body {
        margin: 0;
    }

    }
</style>
