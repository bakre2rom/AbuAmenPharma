@using AbuAmenPharma.ViewModels
@model List<BatchStockVM>
@{
    ViewData["Title"] = "المخزون حسب الدفعة";
    var q = (string)(ViewBag.Q ?? "");
}

<h3 class="mb-3">المخزون حسب الدفعة</h3>

<form method="get" class="card p-3 mb-3">
    <div class="row">
        <div class="col-md-6">
            <label class="form-label">بحث (اسم الصنف / رقم الباتش)</label>
            <input name="q" class="form-control" value="@q" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button class="btn btn-primary">عرض</button>
        </div>
        <div class="col-md-4 d-flex align-items-end justify-content-end">
            <a class="btn btn-outline-danger" asp-action="ExpiryAlert" asp-route-days="90">تنبيه الانتهاء</a>
        </div>
    </div>
</form>

<table class="table table-striped table-bordered align-middle">
    <thead>
        <tr>
            <th>الصنف</th>
            <th class="text-center">دفعة</th>
            <th class="text-center">انتهاء</th>
            <th class="text-end">الرصيد</th>
            <th class="text-center">أيام للانتهاء</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var x in Model)
        {
            var days = x.DaysToExpiry;
            var badge = days < 0 ? "table-danger" : (days <= 30 ? "table-warning" : "");
            <tr class="@badge">
                <td>@x.ItemName</td>
                <td class="text-center">@x.BatchNo</td>
                <td class="text-center">@x.ExpiryDate.ToString("yyyy-MM-dd")</td>
                <td class="text-end"><strong>@x.Balance</strong></td>
                <td class="text-center">@days</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr class="table-dark">
            <th colspan="3">الإجمالي</th>
            <th class="text-end">@Model.Sum(x => x.Balance)</th>
            <th></th>
        </tr>
    </tfoot>
</table>
