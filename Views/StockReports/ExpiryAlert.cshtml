@using AbuAmenPharma.ViewModels
@model List<BatchStockVM>
@{
    ViewData["Title"] = "تنبيه قرب الانتهاء";
    int days = (int)(ViewBag.Days ?? 90);
    var q = (string)(ViewBag.Q ?? "");
}

<h3 class="mb-3">تنبيه قرب الانتهاء / المنتهي</h3>

<form method="get" class="card p-3 mb-3">
    <div class="row">
        <div class="col-md-3">
            <label class="form-label">خلال (يوم)</label>
            <input name="days" type="number" class="form-control" value="@days" min="1" />
        </div>

        <div class="col-md-5">
            <label class="form-label">بحث (اسم الصنف / رقم الدفعة)</label>
            <input name="q" class="form-control" value="@q" />
        </div>

        <div class="col-md-2 d-flex align-items-end">
            <button class="btn btn-primary">عرض</button>
        </div>

        <div class="col-md-2 d-flex align-items-end justify-content-end">
            <a class="btn btn-outline-secondary" asp-action="StockByBatch">كل المخزون</a>
        </div>
    </div>
</form>

<div class="alert alert-info">
    يتم عرض الدفعات التي رصيدها أكبر من صفر وتاريخ انتهائها خلال <strong>@days</strong> يوم (يشمل المنتهي).
</div>

<table class="table table-striped table-bordered align-middle">
    <thead>
        <tr>
            <th>الصنف</th>
            <th class="text-center">دفعة</th>
            <th class="text-center">انتهاء</th>
            <th class="text-end">الرصيد</th>
            <th class="text-center">أيام للانتهاء</th>
            <th class="text-center">الحالة</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var x in Model)
        {
            var d = x.DaysToExpiry ?? 999999;
            var status = d < 0 ? "منتهي" : (d <= 30 ? "قريب جدًا" : "قريب");
            var rowClass = d < 0 ? "table-danger" : (d <= 30 ? "table-warning" : "");
            <tr class="@rowClass">
                <td>@x.ItemName</td>
                <td class="text-center">@x.BatchNo</td>
                <td class="text-center">@x.ExpiryDate</td>
                <td class="text-end"><strong>@x.Balance</strong></td>
                <td class="text-center">@x.DaysToExpiry</td>
                <td class="text-center">@status</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr class="table-dark">
            <th colspan="3">الإجمالي</th>
            <th class="text-end">@Model.Sum(x => x.Balance)</th>
            <th colspan="2"></th>
        </tr>
    </tfoot>
</table>