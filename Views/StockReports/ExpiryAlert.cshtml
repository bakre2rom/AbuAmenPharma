@using AbuAmenPharma.ViewModels
@model List<BatchStockVM>
@{
    ViewData["Title"] = "تنبيه قرب الانتهاء";
    int days = (int)(ViewBag.Days ?? 90);
    var q = (string)(ViewBag.Q ?? "");
    var totalBalance = Model.Sum(x => x.Balance);
    var expiredCount = Model.Count(x => x.DaysToExpiry < 0);
    var urgentCount = Model.Count(x => x.DaysToExpiry >= 0 && x.DaysToExpiry <= 30);
}

<section class="expiry-page">
    <div class="expiry-hero card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div>
                    <h2 class="mb-1">تنبيه الانتهاء والمنتهي</h2>
                    <p class="mb-0 text-muted">مراجعة الدفعات القريبة من انتهاء الصلاحية لاتخاذ قرار سريع قبل خسارة المخزون.</p>
                </div>
                <div class="hero-chips">
                    <span class="chip chip-soft">الدفعات: @Model.Count</span>
                    <span class="chip chip-danger">منتهي: @expiredCount</span>
                    <span class="chip chip-warning">قريب جدا: @urgentCount</span>
                    <span class="chip chip-primary">الرصيد: @totalBalance.ToString("N2")</span>
                </div>
            </div>
        </div>
    </div>

    <form method="get" class="card border-0 shadow-sm mb-3 filter-card">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-lg-2 col-md-3">
                    <label class="form-label fw-semibold">خلال (يوم)</label>
                    <input name="days" type="number" class="form-control" value="@days" min="1" />
                </div>

                <div class="col-lg-6 col-md-5">
                    <label class="form-label fw-semibold">بحث (اسم الصنف / رقم الدفعة)</label>
                    <input name="q" class="form-control" value="@q" placeholder="اكتب اسم الصنف أو رقم الدفعة" />
                </div>

                <div class="col-lg-2 col-md-2 d-grid">
                    <button class="btn btn-primary btn-filter">عرض النتائج</button>
                </div>

                <div class="col-lg-2 col-md-2 d-grid">
                    <a class="btn btn-outline-secondary" asp-action="StockByBatch">كل المخزون</a>
                </div>
            </div>
        </div>
    </form>

    <div class="alert alert-info border-0 shadow-sm info-alert">
        يتم عرض الدفعات ذات الرصيد الأكبر من صفر والتي تنتهي خلال <strong>@days</strong> يوم، ويشمل ذلك الدفعات المنتهية.
    </div>

    <div class="card border-0 shadow-sm table-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 expiry-table">
                    <thead>
                        <tr>
                            <th>الصنف</th>
                            <th class="text-center">دفعة</th>
                            <th class="text-center">انتهاء</th>
                            <th class="text-end">الرصيد</th>
                            <th class="text-center">أيام للانتهاء</th>
                            <th class="text-center">الحالة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">لا توجد دفعات مطابقة للفلترة الحالية.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var x in Model)
                            {
                                var d = x.DaysToExpiry;
                                var statusText = d < 0 ? "منتهي" : (d <= 30 ? "قريب جدًا" : "قريب");
                                var badgeClass = d < 0 ? "status-expired" : (d <= 30 ? "status-urgent" : "status-soon");
                                <tr>
                                    <td class="fw-semibold">@x.ItemName</td>
                                    <td class="text-center">@x.BatchNo</td>
                                    <td class="text-center">@x.ExpiryDate.ToString("yyyy-MM-dd")</td>
                                    <td class="text-end fw-bold">@x.Balance.ToString("N2")</td>
                                    <td class="text-center">@x.DaysToExpiry</td>
                                    <td class="text-center"><span class="status-pill @badgeClass">@statusText</span></td>
                                </tr>
                            }
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3">إجمالي الرصيد</th>
                            <th class="text-end">@totalBalance.ToString("N2")</th>
                            <th colspan="2"></th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        .expiry-page {
            --expiry-primary: #1f7a64;
            --expiry-soft: #ecf8f4;
            --expiry-border: #e5e7eb;
            --expiry-text: #334155;
        }

        .expiry-page .expiry-hero {
            background: linear-gradient(135deg, #ffffff 0%, #f6fbf9 60%, #edf8f3 100%);
            border: 1px solid var(--expiry-border);
            border-radius: 16px;
        }

        .expiry-page .expiry-hero h2 {
            font-size: 2rem;
            margin: 0;
            color: #0f172a;
        }

        .expiry-page .hero-chips {
            display: flex;
            flex-wrap: wrap;
            gap: 0.45rem;
        }

        .expiry-page .chip {
            border-radius: 999px;
            padding: 0.3rem 0.8rem;
            font-size: 0.84rem;
            font-weight: 700;
            border: 1px solid transparent;
        }

        .expiry-page .chip-soft {
            background: #f1f5f9;
            color: #334155;
            border-color: #e2e8f0;
        }

        .expiry-page .chip-primary {
            background: #e6f4ef;
            color: #0f5132;
            border-color: #c9e9dc;
        }

        .expiry-page .chip-warning {
            background: #fff8e7;
            color: #8a6400;
            border-color: #ffe6a7;
        }

        .expiry-page .chip-danger {
            background: #feeceb;
            color: #9f1239;
            border-color: #f8c7c6;
        }

        .expiry-page .filter-card,
        .expiry-page .table-card,
        .expiry-page .info-alert {
            border-radius: 14px;
            border: 1px solid var(--expiry-border);
        }

        .expiry-page .btn-filter {
            font-weight: 700;
        }

        .expiry-page .info-alert {
            background: #eef7fb;
            color: #0f4864;
        }

        .expiry-page .expiry-table thead th {
            background: #f8fafc;
            color: #475569;
            font-weight: 700;
            border-bottom: 1px solid var(--expiry-border);
        }

        .expiry-page .expiry-table tbody tr:hover {
            background: #f9fcfb;
        }

        .expiry-page .expiry-table tfoot th {
            background: #f7fafc;
            color: var(--expiry-text);
            font-weight: 700;
            border-top: 2px solid #d7e2ea;
        }

        .expiry-page .status-pill {
            display: inline-block;
            min-width: 92px;
            border-radius: 999px;
            padding: 0.2rem 0.55rem;
            font-size: 0.78rem;
            font-weight: 700;
            border: 1px solid transparent;
        }

        .expiry-page .status-expired {
            background: #fff1f2;
            color: #be123c;
            border-color: #fecdd3;
        }

        .expiry-page .status-urgent {
            background: #fff8e6;
            color: #a16207;
            border-color: #fde68a;
        }

        .expiry-page .status-soon {
            background: #eaf5ff;
            color: #1d4ed8;
            border-color: #bfdbfe;
        }

        @@media (max-width: 768px) {
            .expiry-page .expiry-hero h2 {
                font-size: 1.6rem;
            }
        }
    </style>
}
