@using AbuAmenPharma.ViewModels
@model HomeDashboardVM
@{
    ViewData["Title"] = "الرئيسية";
}

<h3 class="mb-3">لوحة التحكم</h3>

<div class="row g-3">
    <div class="col-md-3">
        <div class="card p-3">
            <div class="text-muted">مبيعات اليوم</div>
            <div class="fs-4"><strong>@Model.SalesTodayNet</strong></div>
            <div class="text-muted">عدد الفواتير: @Model.SalesTodayCount</div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3">
            <div class="text-muted">مبيعات الشهر</div>
            <div class="fs-4"><strong>@Model.SalesMonthNet</strong></div>
            <div class="text-muted">من بداية الشهر</div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3">
            <div class="text-muted">غير مسدد</div>
            <div class="fs-4"><strong>@Model.UnpaidInvoicesRemaining</strong></div>
            <div class="text-muted">عدد: @Model.UnpaidInvoicesCount</div>
            <a class="btn btn-sm btn-outline-primary mt-2" asp-controller="SalesReports" asp-action="Aging">فتح التقرير</a>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3">
            <div class="text-muted">تحصيل اليوم</div>
            <div class="fs-4"><strong>@Model.ReceiptsTodayTotal</strong></div>
            <div class="text-muted">سندات القبض اليوم</div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-md-4">
        <div class="card p-3">
            <div class="text-muted">دفعات منتهية (برصيد)</div>
            <div class="fs-4"><strong>@Model.ExpiredBatchesCount</strong></div>
            <a class="btn btn-sm btn-outline-danger mt-2" asp-controller="StockReports" asp-action="ExpiryAlert" asp-route-days="0">عرض</a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3">
            <div class="text-muted">قرب الانتهاء خلال 30 يوم</div>
            <div class="fs-4"><strong>@Model.ExpiringSoonBatchesCount</strong></div>
            <a class="btn btn-sm btn-outline-warning mt-2" asp-controller="StockReports" asp-action="ExpiryAlert" asp-route-days="30">عرض</a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3">
            <div class="text-muted">أصناف بدون رصيد</div>
            <div class="fs-4"><strong>@Model.OutOfStockItemsCount</strong></div>
            <a class="btn btn-sm btn-outline-secondary mt-2" asp-controller="StockReports" asp-action="StockByBatch">المخزون حسب الدفعة</a>
        </div>
    </div>
</div>

<div class="card p-3 mt-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0">أكثر الأدوية مبيعاً هذا الشهر</h5>
        <span class="text-muted small">Top 5</span>
    </div>

    @if (Model.TopItems == null || Model.TopItems.Count == 0)
    {
        <div class="text-muted">لا توجد بيانات كافية.</div>
    }
    else
    {
        <table class="table table-striped table-bordered mb-0">
            <thead>
                <tr>
                    <th>الدواء</th>
                    <th class="text-end">الكمية</th>
                    <th style="width:120px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var x in Model.TopItems)
                {
                    <tr>
                        <td>@x.ItemName</td>
                        <td class="text-end"><strong>@x.Qty</strong></td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-controller="Items" asp-action="Details" asp-route-id="@x.ItemId">فتح</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>