@using AbuAmenPharma.ViewModels
@using System.Globalization
@model HomeDashboardVM
@{
    ViewData["Title"] = "الرئيسية";
    var todayLabel = DateTime.Now.ToString("dddd، dd MMMM yyyy", new CultureInfo("ar-SA"));
    var topMaxQty = Model.TopItems != null && Model.TopItems.Count > 0 ? Model.TopItems.Max(x => x.Qty) : 0m;
}

<section class="home-dashboard">
    <div class="card home-hero border-0 shadow-sm reveal">
        <div class="card-body p-4 p-lg-5">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <span class="hero-badge">ملخص اليوم</span>
                    <h1 class="hero-title mt-2 mb-2">لوحة التشغيل </h1>
                    <p class="hero-subtitle mb-3">
                        متابعة المبيعات والتحصيل والمخزون من شاشة واحدة لتسريع القرار اليومي.
                    </p>
                    <div class="d-flex flex-wrap gap-3 hero-meta">
                        <span><i class="bi bi-calendar3"></i> @todayLabel</span>
                        <span><i class="bi bi-graph-up-arrow"></i> تحديث مباشر للمؤشرات</span>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="quick-actions">
                        <a class="action-chip" asp-controller="Sales" asp-action="Create">
                            <i class="bi bi-receipt"></i> فاتورة بيع
                        </a>
                        <a class="action-chip" asp-controller="Purchases" asp-action="Create">
                            <i class="bi bi-cart-check"></i> فاتورة شراء
                        </a>
                        <a class="action-chip" asp-controller="CustomerReceipts" asp-action="Create">
                            <i class="bi bi-wallet2"></i> سند قبض
                        </a>
                        <a class="action-chip" asp-controller="Items" asp-action="LowStock">
                            <i class="bi bi-exclamation-triangle"></i> نواقص المخزون
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-sm-6 col-xl-3">
            <div class="card metric-card border-0 shadow-sm reveal delay-1">
                <div class="card-body">
                    <div class="metric-head">
                        <span>مبيعات اليوم</span>
                        <i class="bi bi-currency-exchange"></i>
                    </div>
                    <div class="metric-value"><small>SDG</small> @Model.SalesTodayNet.ToString("N2")</div>
                    <div class="metric-note">عدد الفواتير: @Model.SalesTodayCount</div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card metric-card border-0 shadow-sm reveal delay-2">
                <div class="card-body">
                    <div class="metric-head">
                        <span>مبيعات الشهر</span>
                        <i class="bi bi-bar-chart-line"></i>
                    </div>
                    <div class="metric-value"><small>SDG</small> @Model.SalesMonthNet.ToString("N2")</div>
                    <div class="metric-note">من بداية الشهر الحالي</div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card metric-card border-0 shadow-sm reveal delay-3">
                <div class="card-body">
                    <div class="metric-head">
                        <span>فواتير غير مسددة</span>
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div class="metric-value"><small>SDG</small> @Model.UnpaidInvoicesRemaining.ToString("N2")</div>
                    <div class="metric-note d-flex justify-content-between align-items-center">
                        <span>عدد الفواتير: @Model.UnpaidInvoicesCount</span>
                        <a class="metric-link" asp-controller="SalesReports" asp-action="Aging">تفاصيل</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card metric-card border-0 shadow-sm reveal delay-4">
                <div class="card-body">
                    <div class="metric-head">
                        <span>تحصيل اليوم</span>
                        <i class="bi bi-cash-coin"></i>
                    </div>
                    <div class="metric-value"><small>SDG</small> @Model.ReceiptsTodayTotal.ToString("N2")</div>
                    <div class="metric-note">إجمالي سندات القبض اليوم</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-md-4">
            <div class="card alert-card border-0 shadow-sm reveal delay-1">
                <div class="card-body">
                    <div class="alert-title text-danger"><i class="bi bi-exclamation-octagon"></i> دفعات منتهية</div>
                    <div class="alert-value">@Model.ExpiredBatchesCount</div>
                    <p class="alert-text mb-3">دفعات منتهية الصلاحية وبها رصيد متاح.</p>
                    <a class="btn btn-sm btn-outline-danger rounded-pill px-3" asp-controller="StockReports" asp-action="ExpiryAlert" asp-route-days="0">عرض التفاصيل</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card alert-card border-0 shadow-sm reveal delay-2">
                <div class="card-body">
                    <div class="alert-title text-warning"><i class="bi bi-hourglass-split"></i> قرب الانتهاء</div>
                    <div class="alert-value">@Model.ExpiringSoonBatchesCount</div>
                    <p class="alert-text mb-3">دفعات ستنتهي خلال 30 يوم القادمة.</p>
                    <a class="btn btn-sm btn-outline-warning rounded-pill px-3" asp-controller="StockReports" asp-action="ExpiryAlert" asp-route-days="30">فتح التقرير</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card alert-card border-0 shadow-sm reveal delay-3">
                <div class="card-body">
                    <div class="alert-title text-secondary"><i class="bi bi-box-seam"></i> أصناف بدون رصيد</div>
                    <div class="alert-value">@Model.OutOfStockItemsCount</div>
                    <p class="alert-text mb-3">أصناف فعالة تحتاج إعادة تموين سريع.</p>
                    <a class="btn btn-sm btn-outline-secondary rounded-pill px-3" asp-controller="StockReports" asp-action="StockByBatch">المخزون حسب الدفعات</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mt-3 reveal delay-4 top-items-card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0 fw-bold">أكثر الأدوية مبيعاً هذا الشهر</h5>
                <span class="top-badge">Top 5</span>
            </div>

            @if (Model.TopItems == null || Model.TopItems.Count == 0)
            {
                <div class="empty-state">
                    <i class="bi bi-clipboard2-data"></i>
                    <span>لا توجد بيانات كافية لعرض الترتيب حالياً.</span>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>الدواء</th>
                                <th style="width: 160px;">الكمية</th>
                                <th>مستوى الأداء</th>
                                <th style="width: 120px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var x in Model.TopItems)
                            {
                                var percent = topMaxQty <= 0 ? 0 : (int)Math.Round((x.Qty / topMaxQty) * 100m);
                                <tr>
                                    <td class="fw-semibold">@x.ItemName</td>
                                    <td><span class="qty-pill">@x.Qty.ToString("N0")</span></td>
                                    <td>
                                        <div class="progress progress-soft" role="progressbar" aria-label="Top item ratio" aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100">
                                            <div class="progress-bar" style="@($"width:{percent}%")"></div>
                                        </div>
                                    </td>
                                    <td>
                                        <a class="btn btn-sm btn-outline-primary rounded-pill px-3" asp-controller="Items" asp-action="Details" asp-route-id="@x.ItemId">فتح</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>

@section Styles {
    <style>
        .home-dashboard {
            --home-primary: #1f7a64;
            --home-primary-soft: #e6f4ef;
            --home-ink: #1f2937;
            --home-muted: #6b7280;
            --home-border: #e5e7eb;
            --home-cream: #f8fafc;
            margin-top: 1rem;
            margin-bottom: 1.25rem;
        }

        .home-dashboard .home-hero {
            background: linear-gradient(135deg, #0f5132 0%, #1f7a64 52%, #e7f7ef 100%);
            position: relative;
            overflow: hidden;
            border-radius: 18px;
        }

        .home-dashboard .home-hero::before,
        .home-dashboard .home-hero::after {
            content: "";
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
        }

        .home-dashboard .home-hero::before {
            width: 260px;
            height: 260px;
            top: -130px;
            left: -60px;
            background: rgba(255, 255, 255, 0.15);
        }

        .home-dashboard .home-hero::after {
            width: 180px;
            height: 180px;
            bottom: -90px;
            right: -50px;
            background: rgba(255, 255, 255, 0.22);
        }

        .home-dashboard .home-hero .card-body {
            position: relative;
            z-index: 1;
            padding: 2rem !important;
        }

        .home-dashboard .hero-badge {
            display: inline-flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.2);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.35);
            border-radius: 999px;
            padding: 0.3rem 0.85rem;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .home-dashboard .hero-title {
            color: #fff;
            font-size: 1.95rem;
            font-weight: 700;
            line-height: 1.25;
        }

        .home-dashboard .hero-subtitle {
            color: rgba(255, 255, 255, 0.95);
            max-width: 620px;
            font-size: 1rem;
        }

        .home-dashboard .hero-meta span {
            color: rgba(255, 255, 255, 0.92);
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }

        .home-dashboard .quick-actions {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.65rem;
        }

        .home-dashboard .action-chip {
            text-decoration: none;
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid rgba(255, 255, 255, 0.6);
            color: #12483a;
            border-radius: 12px;
            padding: 0.7rem 0.8rem;
            font-weight: 600;
            font-size: 0.88rem;
            display: flex;
            align-items: center;
            gap: 0.45rem;
            transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
        }

        .home-dashboard .action-chip:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(15, 81, 50, 0.16);
            background: #fff;
            color: #0f5132;
        }

        .home-dashboard .metric-card,
        .home-dashboard .alert-card,
        .home-dashboard .top-items-card {
            border-radius: 14px;
            background: #fff;
            border: 1px solid var(--home-border);
        }

        .home-dashboard .metric-card .card-body,
        .home-dashboard .alert-card .card-body,
        .home-dashboard .top-items-card .card-body {
            padding: 1rem !important;
        }

        .home-dashboard .metric-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            color: var(--home-muted);
            font-size: 0.9rem;
        }

        .home-dashboard .metric-head i {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--home-primary-soft);
            color: var(--home-primary);
        }

        .home-dashboard .metric-value {
            font-size: 1.45rem;
            font-weight: 700;
            color: var(--home-ink);
            margin-top: 0.55rem;
        }

        .home-dashboard .metric-value small {
            font-size: 0.8rem;
            color: var(--home-muted);
            font-weight: 600;
        }

        .home-dashboard .metric-note {
            margin-top: 0.4rem;
            color: var(--home-muted);
            font-size: 0.86rem;
        }

        .home-dashboard .metric-link {
            color: var(--home-primary);
            text-decoration: none;
            font-weight: 600;
        }

        .home-dashboard .metric-link:hover {
            text-decoration: underline;
        }

        .home-dashboard .alert-title {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            font-weight: 700;
            font-size: 0.95rem;
        }

        .home-dashboard .alert-value {
            font-size: 2rem;
            line-height: 1.1;
            font-weight: 700;
            color: var(--home-ink);
            margin-top: 0.35rem;
        }

        .home-dashboard .alert-text {
            color: var(--home-muted);
            font-size: 0.88rem;
        }

        .home-dashboard .top-badge {
            background: #eef2ff;
            color: #3730a3;
            border-radius: 999px;
            padding: 0.2rem 0.65rem;
            font-size: 0.76rem;
            font-weight: 700;
        }

        .home-dashboard .top-items-card table thead th {
            color: var(--home-muted);
            font-weight: 600;
            border-bottom-color: var(--home-border);
        }

        .home-dashboard .qty-pill {
            display: inline-block;
            min-width: 72px;
            text-align: center;
            background: #f3f4f6;
            color: #111827;
            border-radius: 999px;
            padding: 0.2rem 0.65rem;
            font-weight: 700;
        }

        .home-dashboard .progress-soft {
            height: 8px;
            background-color: #ebf2ef;
            border-radius: 999px;
            overflow: hidden;
        }

        .home-dashboard .progress-soft .progress-bar {
            background: linear-gradient(90deg, #1f7a64, #39a686);
            border-radius: 999px;
        }

        .home-dashboard .empty-state {
            border: 1px dashed #cbd5e1;
            border-radius: 12px;
            background: #f8fafc;
            color: var(--home-muted);
            display: flex;
            align-items: center;
            gap: 0.6rem;
            padding: 1rem;
            font-weight: 600;
        }

        .home-dashboard .reveal {
            opacity: 0;
            transform: translateY(12px);
            animation: dashboardReveal 0.5s ease-out forwards;
        }

        .home-dashboard .delay-1 { animation-delay: 0.05s; }
        .home-dashboard .delay-2 { animation-delay: 0.12s; }
        .home-dashboard .delay-3 { animation-delay: 0.2s; }
        .home-dashboard .delay-4 { animation-delay: 0.28s; }

        @@keyframes dashboardReveal {
            from {
                opacity: 0;
                transform: translateY(12px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width: 991.98px) {
            .home-dashboard .hero-title {
                font-size: 1.6rem;
            }

            .home-dashboard .quick-actions {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 575.98px) {
            .home-dashboard .hero-meta {
                flex-direction: column;
                align-items: flex-start !important;
                gap: 0.45rem !important;
            }

            .home-dashboard .metric-value {
                font-size: 1.3rem;
            }
        }
    </style>
}

