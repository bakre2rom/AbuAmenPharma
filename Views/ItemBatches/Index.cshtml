@using AbuAmenPharma.ViewModels
@model IEnumerable<ItemBatchListVM>
@{
    var hasItemFilter = ViewBag.HasItemFilter is bool flag && flag;
    var itemName = ViewBag.ItemName as string ?? "كل الدفعات";
    ViewData["Title"] = ViewData["Title"] ?? (hasItemFilter ? $"دفعات الصنف: {itemName}" : "إدارة الدفعات");
}

<div class="row justify-content-center">
    <div class="col-lg-12">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-2 mt-1">
            <div>
                @if (hasItemFilter)
                {
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-box me-1"></i> دفعات الصنف</h5>
                    <small class="text-muted fw-semibold">الصنف: @itemName</small>
                }
                else
                {
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-boxes me-1"></i> كل دفعات الأصناف</h5>
                    <small class="text-muted fw-semibold">عرض سريع لكل الدفعات النشطة في النظام</small>
                }
            </div>
            <div class="d-flex gap-2">
                <a class="btn btn-sm btn-outline-secondary px-3 rounded-pill shadow-sm d-flex align-items-center gap-2" asp-controller="Items" asp-action="Index">
                    <i class="bi bi-arrow-right"></i> الأدوية
                </a>
            </div>
        </div>
        <div class="alert alert-info py-2 px-3 mb-3">
            إنشاء دفعة جديدة يتم من خلال <strong>فاتورة شراء</strong> فقط لضمان ترحيل المخزون والمحاسبة بشكل صحيح.
        </div>

        <!-- Card Container -->
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-3">
                <div class="table-responsive">
                    <table class="table table-hover align-middle w-100" id="batchesTable" style="margin-top: 15px;">
                        <thead class="table-light text-muted">
                            <tr>
                                @if (!hasItemFilter)
                                {
                                    <th class="fw-semibold pb-3">الصنف</th>
                                }
                                <th class="fw-semibold pb-3">رقم الباتش</th>
                                <th class="fw-semibold pb-3 text-center">تاريخ الانتهاء</th>
                                <th class="fw-semibold pb-3 text-center">سعر الشراء</th>
                                <th class="fw-semibold pb-3 text-center">سعر البيع</th>
                                <th class="fw-semibold pb-3 text-center">الرصيد</th>
                                <th class="fw-semibold pb-3 text-center" style="width:120px;">العمليات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="@(hasItemFilter ? 6 : 7)" class="text-center text-muted py-4">
                                        لا توجد دفعات لعرضها حالياً.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var b in Model)
                                {
                                    <tr>
                                        @if (!hasItemFilter)
                                        {
                                            <td><span class="fw-semibold text-dark">@b.ItemNameAr</span></td>
                                        }
                                        <td><span class="fw-bold text-dark">@b.BatchNo</span></td>
                                        <td class="text-center">@b.ExpiryDate</td>
                                        <td class="text-center">@b.PurchasePrice</td>
                                        <td class="text-center">@b.SellPrice</td>
                                        <td class="text-center"><span class="badge rounded-pill bg-success px-3 py-2 fs-6">@b.Balance</span></td>
                                        <td class="text-center">
                                            <div class="d-flex justify-content-center gap-2">
                                                <a class="btn btn-outline-secondary floating-action-btn" asp-action="Edit" asp-route-id="@b.Id" data-bs-toggle="tooltip" title="تعديل"><i class="bi bi-pencil"></i></a>
                                                <a class="btn btn-outline-danger floating-action-btn" asp-action="Disable" asp-route-id="@b.Id" data-bs-toggle="tooltip" title="تعطيل"><i class="bi bi-x-lg"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/lib/datatables/css/datatables.bootstrap.min.css" rel="stylesheet" />
    <style>
        .table > :not(caption) > * > * {
            padding: 1rem 0.5rem;
            color: #495057;
        }
        .dataTables_wrapper .dataTables_filter input {
            border-radius: 8px;
            padding: 8px;
            border: 1px solid #dee2e6;
            margin-bottom: 15px;
        }
        table.dataTable.table-striped > tbody > tr.odd > * {
            box-shadow: none;
        }
    </style>
}

@section Scripts {
    <script src="~/lib/datatables/js/jquery.datatables.min.js"></script>
    <script src="~/lib/datatables/js/datatables.bootstrap.min.js"></script>

    <script>
        $(document).ready(function() {
            $('#batchesTable').DataTable({
                order: [[@(!hasItemFilter ? 2 : 1), 'asc']], // Order by expiry date usually
                pageLength: 5,
                language: {
                    search: "_INPUT_",
                    searchPlaceholder: "ابحث عن أي شيء هنا...",
                    lengthMenu: "عرض _MENU_ سجل",
                    info: "عرض _START_ إلى _END_ من إجمالي _TOTAL_ سجل",
                    infoEmpty: "تعرض 0 إلى 0 من أصل 0 سجل",
                    zeroRecords: "لم يتم العثور على سجلات متطابقة",
                    paginate: { first: "الأول", last: "الأخير", next: "التالي", previous: "السابق" }
                }
            });
        });
    </script>
}
