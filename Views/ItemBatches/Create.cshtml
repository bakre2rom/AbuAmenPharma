@model ItemBatch
@{
    ViewData["Title"] = "إضافة دفعة";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 rounded-3 mt-3">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h3 class="mb-0 text-primary">إضافة دفعة - @ViewBag.ItemName</h3>
                <p class="text-muted small">يرجى ملء البيانات التالية لإضافة دفعة جديدة للصنف</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <input type="hidden" asp-for="ItemId" />

                    <div class="mb-4">
                        <label class="form-label fw-semibold">رقم الدفعة</label>
                        <input class="form-control bg-light" value="@Model.BatchNo" readonly />
                        <input type="hidden" asp-for="BatchNo" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">تاريخ الانتهاء <span class="text-danger">*</span></label>
                        <input asp-for="ExpiryDate" class="form-control bg-light" type="date" />
                        <span asp-validation-for="ExpiryDate" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">سعر الشراء</label>
                            <div class="input-group">
                                <input asp-for="PurchasePrice" class="form-control bg-light" type="number" step="0.01" />
                                <span class="input-group-text">SDG</span>
                            </div>
                            <span asp-validation-for="PurchasePrice" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">سعر البيع</label>
                            <div class="input-group">
                                <input asp-for="SellPrice" class="form-control bg-light" type="number" step="0.01" />
                                <span class="input-group-text">SDG</span>
                            </div>
                            <span asp-validation-for="SellPrice" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 pt-2 border-top">
                        <a class="btn btn-outline-secondary px-4" asp-action="Index" asp-route-itemId="@Model.ItemId">إلغاء</a>
                        <button type="submit" class="btn btn-primary px-4 shadow-sm">حفظ البيانات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}