@model Customer
@{
    ViewData["Title"] = "تعديل عميل";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 rounded-3 mt-3">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h3 class="mb-0 text-primary">تعديل عميل</h3>
                <p class="text-muted small">تعديل بيانات العميل المحدد وتحديثها في النظام</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-4">
                        <label class="form-label fw-semibold">اسم العميل <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control bg-light" placeholder="مثال: صيدلية الشفاء" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">الهاتف</label>
                        <input asp-for="Phone" class="form-control bg-light" placeholder="01xxxxxxxxx" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">العنوان</label>
                        <input asp-for="Address" class="form-control bg-light" placeholder="عنوان العميل" />
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">المندوب المسؤول <span class="text-danger">*</span></label>
                        <select asp-for="SalesmanId" class="form-select bg-light" asp-items="ViewBag.SalesmanId">
                            <option value="">اختر المندوب...</option>
                        </select>
                        <span asp-validation-for="SalesmanId" class="text-danger small"></span>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input class="form-check-input" type="checkbox" role="switch" id="isActiveSwitch" asp-for="IsActive">
                        <label class="form-check-label fw-semibold ms-2" for="isActiveSwitch">تفعيل العميل</label>
                    </div>

                    <div class="d-flex justify-content-end gap-2 pt-2 border-top">
                        <a class="btn btn-outline-secondary px-4" asp-action="Index">إلغاء</a>
                        <button type="submit" class="btn btn-primary px-4 shadow-sm">حفظ التغييرات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
