@model IEnumerable<Customer>
@{
    ViewData["Title"] = "إدارة العملاء";
}

<partial name="ERP_Components/_ERPRowActionsStyles" />

<div class="row justify-content-center">
    <div class="col-lg-12">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-3 mt-1">
            <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-people me-2 text-primary"></i> إدارة العملاء</h5>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-sm btn-primary px-3 rounded-pill shadow-sm d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#createCustomerModal">
                    <i class="bi bi-plus-lg"></i> إضافة عميل جديد
                </button>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success py-2 px-3 small border-0 shadow-sm rounded-3 mb-3">@TempData["SuccessMessage"]</div>
        }

        <!-- Card Container -->
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-3">
                <div class="table-responsive">
                    <table class="table table-hover align-middle w-100" id="customersTable">
                        <thead class="table-light">
                            <tr>
                                <th>اسم العميل</th>
                                <th>المندوب</th>
                                <th>الهاتف</th>
                                <th>العنوان</th>
                                <th class="text-center" style="width:120px;">العمليات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td><span class="fw-bold text-dark">@c.Name</span></td>
                                    <td>@(c.Salesman?.NameAr ?? "-")</td>
                                    <td>@(string.IsNullOrWhiteSpace(c.Phone) ? "-" : c.Phone)</td>
                                    <td>@(string.IsNullOrWhiteSpace(c.Address) ? "-" : c.Address)</td>
                                    <td>
                                        <div class="row-actions">
                                            <a href="/Customers/Details/@c.Id" class="row-btn row-btn-view" title="تفاصيل"><i class="bi bi-eye"></i></a>
                                            <button type="button" class="row-btn row-btn-edit edit-customer-btn" 
                                                    data-bs-toggle="modal" data-bs-target="#editCustomerModal"
                                                    data-id="@c.Id" data-name="@c.Name" data-phone="@c.Phone"
                                                    data-address="@(c.Address ?? "")" data-salesman-id="@(c.SalesmanId?.ToString() ?? "")"
                                                    data-is-active="@(c.IsActive ? "true" : "false")" title="تعديل">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button type="button" class="row-btn row-btn-delete disable-customer-btn" 
                                                    data-bs-toggle="modal" data-bs-target="#disableCustomerModal"
                                                    data-id="@c.Id" data-name="@c.Name" title="تعطيل">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Customer Modal -->
<div class="modal fade" id="createCustomerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title fw-bold">إضافة عميل جديد</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" method="post" id="createCustomerForm">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4 bg-white">
                    <partial name="ERP_Components/_ERPLabeledInput" model='new AbuAmenPharma.ViewModels.ERPLabeledInputVM { Label = "اسم العميل", Name = "Name", Required = true, Placeholder = "مثال: صيدلية الشفاء" }' />
                    <partial name="ERP_Components/_ERPLabeledInput" model='new AbuAmenPharma.ViewModels.ERPLabeledInputVM { Label = "الهاتف", Name = "Phone", Placeholder = "01xxxxxxxxx" }' />
                    <partial name="ERP_Components/_ERPLabeledInput" model='new AbuAmenPharma.ViewModels.ERPLabeledInputVM { Label = "العنوان", Name = "Address", Placeholder = "سكن العميل / الحي" }' />
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-dark mb-1">المندوب المسؤول <span class="text-danger">*</span></label>
                        <select name="SalesmanId" class="form-select bg-light border-0" asp-items="ViewBag.SalesmanId" required>
                            <option value="">اختر المندوب...</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm fw-bold">حفظ العميل</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Customer Modal -->
<div class="modal fade" id="editCustomerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-secondary text-white border-0">
                <h5 class="modal-title fw-bold">تعديل بيانات العميل</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Edit" method="post" id="editCustomerForm">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4 bg-white">
                    <input type="hidden" id="editCustomerId" name="Id" />
                    <partial name="ERP_Components/_ERPLabeledInput" model='new AbuAmenPharma.ViewModels.ERPLabeledInputVM { Label = "اسم العميل", Name = "Name", Id = "editCustomerName", Required = true }' />
                    <partial name="ERP_Components/_ERPLabeledInput" model='new AbuAmenPharma.ViewModels.ERPLabeledInputVM { Label = "الهاتف", Name = "Phone", Id = "editCustomerPhone" }' />
                    <partial name="ERP_Components/_ERPLabeledInput" model='new AbuAmenPharma.ViewModels.ERPLabeledInputVM { Label = "العنوان", Name = "Address", Id = "editCustomerAddress" }' />
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-dark mb-1">المندوب المسؤول <span class="text-danger">*</span></label>
                        <select id="editCustomerSalesmanId" name="SalesmanId" class="form-select bg-light border-0" asp-items="ViewBag.SalesmanId" required>
                            <option value="">اختر المندوب...</option>
                        </select>
                    </div>

                    <div class="form-check form-switch mt-3">
                        <input class="form-check-input" type="checkbox" id="editCustomerIsActive" name="IsActive" value="true" checked />
                        <label class="form-check-label fw-bold ms-2" for="editCustomerIsActive">تفعيل الحساب</label>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-secondary px-4 shadow-sm fw-bold">حفظ التغييرات</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Disable Modal -->
<div class="modal fade" id="disableCustomerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white border-0">
                <h5 class="modal-title fw-bold">تعطيل عميل</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Disable" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4 bg-white">
                    <input type="hidden" id="disableCustomerId" name="Id" />
                    <p class="mb-0 fs-5 text-center">هل أنت متأكد من تعطيل العميل: <br /><strong id="disableCustomerName" class="text-danger"></strong> ؟</p>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-danger px-4 shadow-sm fw-bold">تأكيد التعطيل</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/lib/datatables/css/datatables.bootstrap.min.css" rel="stylesheet" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/datatables/js/jquery.datatables.min.js"></script>
    <script src="~/lib/datatables/js/datatables.bootstrap.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#customersTable').DataTable({
                order: [[0, 'asc']],
                pageLength: 6,
                language: {
                    search: "",
                    searchPlaceholder: "بحث سريع...",
                    lengthMenu: "عرض _MENU_",
                    info: "عرض _START_ إلى _END_ من _TOTAL_",
                    paginate: { next: "›", previous: "‹" }
                },
                dom: "<'row mb-2'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row mt-2'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });

            $('.edit-customer-btn').on('click', function () {
                const btn = $(this);
                $('#editCustomerId').val(btn.data('id'));
                $('#editCustomerModal').find('input[name="Name"]').val(btn.data('name'));
                $('#editCustomerModal').find('input[name="Phone"]').val(btn.data('phone'));
                $('#editCustomerModal').find('input[name="Address"]').val(btn.data('address'));
                $('#editCustomerSalesmanId').val((btn.data('salesman-id') ?? '').toString());
                $('#editCustomerIsActive').prop('checked', btn.data('is-active') === 'true' || btn.data('is-active') === true);
            });

            $('.disable-customer-btn').on('click', function () {
                const btn = $(this);
                $('#disableCustomerId').val(btn.data('id'));
                $('#disableCustomerName').text(btn.data('name'));
            });
        });
    </script>
}
