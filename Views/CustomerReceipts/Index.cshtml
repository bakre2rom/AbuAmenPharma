@model IEnumerable<CustomerReceipt>
@{
    ViewData["Title"] = "سندات القبض";
}

<div class="row justify-content-center">
    <div class="col-lg-12">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-2 mt-1">
            <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-receipt-cutoff me-1"></i> سندات القبض</h5>
            <a class="btn btn-sm btn-primary px-3 rounded-pill shadow-sm d-flex align-items-center gap-2" asp-action="Create">
                <i class="bi bi-plus-lg"></i> سند جديد
            </a>
        </div>

        <!-- Card Container -->
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-3">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" id="receiptsTable">
                        <thead class="table-light text-muted">
                            <tr>
                                <th class="fw-semibold pb-3">رقم السند</th>
                                <th class="fw-semibold pb-3">التاريخ</th>
                                <th class="fw-semibold pb-3">العميل</th>
                                <th class="fw-semibold pb-3 text-center">المبلغ</th>
                                <th class="fw-semibold pb-3 text-center">الموزع</th>
                                <th class="fw-semibold pb-3 text-center">غير موزع</th>
                                <th class="fw-semibold pb-3 text-center">الحالة</th>
                                <th class="fw-semibold pb-3 text-center" style="width:120px;">العمليات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model)
                            {
                                var allocated = r.Amount - r.UnallocatedAmount;
                                <tr>
                                    <td data-order="@r.Id"><span class="fw-bold text-primary">RCV-@r.Id#</span></td>
                                    <td>@r.Date.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td class="fw-bold text-dark">@r.Customer?.Name</td>
                                    <td class="text-center">
                                        <small class="text-muted pe-1">SDG</small>
                                        <span class="fw-bold text-success">@r.Amount.ToString("N2")</span>
                                    </td>
                                    <td class="text-center fw-bold text-success">@allocated.ToString("N2")</td>
                                    <td class="text-center">
                                        @if (r.UnallocatedAmount > 0)
                                        {
                                            <span class="badge rounded-pill bg-warning text-dark px-3 py-2">@r.UnallocatedAmount.ToString("N2")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">0.00</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (r.IsActive)
                                        {
                                            if (r.UnallocatedAmount <= 0)
                                            {
                                                <span class="badge rounded-pill bg-success px-3 py-2">موزع بالكامل</span>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill bg-info px-3 py-2">نشط</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-secondary px-3 py-2">معطل</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a class="btn btn-outline-secondary floating-action-btn" asp-action="Details" asp-route-id="@r.Id" data-bs-toggle="tooltip" title="عرض التفاصيل"><i class="bi bi-eye"></i></a>
                                            @if (r.IsActive)
                                            {
                                                <a class="btn btn-outline-danger floating-action-btn" asp-action="Disable" asp-route-id="@r.Id" data-bs-toggle="tooltip" title="تعطيل السند"><i class="bi bi-x-circle"></i></a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/datatables/js/dataTables.bootstrap.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#receiptsTable').DataTable({
                order: [[0, 'desc']],
                pageLength: 5,
                language: {
                    search: "_INPUT_",
                    searchPlaceholder: "ابحث عن أي شيء هنا...",
                    lengthMenu: "عرض _MENU_ سجل",
                    info: "عرض _START_ إلى _END_ من إجمالي _TOTAL_ سجل",
                    infoEmpty: "تعرض 0 إلى 0 من أصل 0 سجل",
                    zeroRecords: "لم يتم العثور على سجلات متطابقة",
                    paginate: { first: "الأول", last: "الأخير", next: "التالي", previous: "السابق" }
                }
            });
        });
    </script>
}
