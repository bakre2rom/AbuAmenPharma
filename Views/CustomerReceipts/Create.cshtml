@using AbuAmenPharma.ViewModels
@model CustomerReceiptCreateVM
@{
    ViewData["Title"] = "سند قبض";
}

<h3 class="mb-3">سند قبض</h3>

<form asp-action="Create" method="post" class="card p-3">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <div class="row">
        <div class="col-md-3 mb-3">
            <label class="form-label">التاريخ</label>
            <input asp-for="Date" class="form-control" type="datetime-local" />
        </div>

        <div class="col-md-6">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">العميل</label>
                    <div class="d-flex gap-1 align-items-start">
                        <div class="flex-grow-1" style="min-width: 0;">
                            <select asp-for="CustomerId" class="form-control" id="customerSelect" style="width:100%"></select>
                        </div>
                        <button type="button" class="btn btn-primary" style="height: 38px;" data-bs-toggle="modal" data-bs-target="#createCustomerModal" title="إضافة عميل سريع">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">الرصيد المستحق الحالي</label>
                    <div class="input-group">
                        <input type="text" id="currentBalance" class="form-control fw-bold text-danger bg-light" readonly value="0.00" />
                        <span class="input-group-text">ج.م</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <label class="form-label">المبلغ</label>
            <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" required />
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">ملاحظات</label>
        <input asp-for="Notes" class="form-control" />
    </div>

    <div class="form-check mb-2">
        <input class="form-check-input" asp-for="AutoAllocate" id="autoAllocateChk" />
        <label class="form-check-label" for="autoAllocateChk">توزيع تلقائي على أقدم الفواتير (FIFO)</label>
    </div>

    <div class="mb-3" id="invoiceBox" style="display:none;">
        <label class="form-label">اختيار فاتورة</label>
        <select asp-for="SaleId" class="form-select" id="invoiceSelect">
            <option value="">اختر فاتورة...</option>
        </select>
        <span asp-validation-for="SaleId" class="text-danger"></span>
        <div class="small text-muted mt-1">سيتم الخصم من الفاتورة المختارة فقط.</div>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-success">حفظ</button>
        <a class="btn btn-secondary" asp-action="Index">رجوع</a>
    </div>
</form>

<!-- Create Customer Modal -->
<div class="modal fade" id="createCustomerModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title">إضافة عميل جديد</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-4">
                    <label class="form-label fw-semibold">اسم العميل <span class="text-danger">*</span></label>
                    <input type="text" id="newCustomerName" class="form-control bg-light" placeholder="اسم العميل..." required />
                </div>
                <div class="mb-4">
                    <label class="form-label fw-semibold">المندوب المسؤول <span class="text-danger">*</span></label>
                    <select id="newCustomerSalesmanId" name="newCustomerSalesmanId" class="form-select bg-light" asp-items="ViewBag.SalesmanId" required>
                        <option value="">اختر المندوب...</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary px-4 shadow-sm" id="saveCustomerBtn">حفظ</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="~/lib/select2/css/select2.min.css" rel="stylesheet" />
    <script src="~/lib/select2/js/select2.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <style>
        .select2-container--default .select2-selection--single {
            height: 38px;
            border: 1px solid #ced4da;
            border-radius: 4px;
        }

            .select2-container--default .select2-selection--single .select2-selection__rendered {
                line-height: 36px;
            }

            .select2-container--default .select2-selection--single .select2-selection__arrow {
                height: 36px;
            }

        .select2-dropdown {
            z-index: 99999;
        }

        .available-quantity {
            background-color: #f8f9fa;
            text-align: center;
            font-weight: bold;
            padding: 8px;
            border-radius: 4px;
        }
    </style>

    <script>
        function toggleInvoiceBox() {
            const auto = $('#autoAllocateChk').is(':checked');
            $('#invoiceBox').toggle(!auto);
        }

        async function loadInvoices(customerId) {
            if (!customerId) return;

            const res = await $.get('@Url.Action("GetOpenInvoices", "CustomerReceipts")', { customerId });
            const $sel = $('#invoiceSelect');
            $sel.empty();
            $sel.append(`<option value="">اختر فاتورة...</option>`);

            (res || []).forEach(x => {
                $sel.append(`<option value="${x.id}">${x.text}</option>`);
            });
        }

        // تهيئة Select2 للعملاء
        function initCustomerSelect2() {
            $('#customerSelect').select2({
                placeholder: 'اختر عميل...',
                allowClear: true,
                dir: 'rtl',
                ajax: {
                    url: '@Url.Action("SearchCustomers", "CustomerReceipts")',
                    dataType: 'json',
                    delay: 250,
                    data: function(params) {
                        return { term: params.term };
                    },
                    processResults: function(data) {
                        return { results: data };
                    }
                }
            });
        }

        $(function(){
            toggleInvoiceBox();

            $('#autoAllocateChk').on('change', function(){
                toggleInvoiceBox();
            });

            $('#customerSelect').on('change', function(){
                const cid = $(this).val();
                loadInvoices(cid);
                updateDueBalance(cid);
            });

            async function updateDueBalance(customerId) {
                if(!customerId) {
                    $('#currentBalance').val('0.00');
                    return;
                }
                try {
                    const res = await $.get('@Url.Action("GetCustomerBalance", "CustomerReceipts")', { customerId });
                    $('#currentBalance').val(res.balance.toLocaleString('en-US', { minimumFractionDigits: 2 }));
                } catch(e) {
                    console.error("Balance fetch error", e);
                }
            }

            // تحميل أولي لو كان العميل مختار
            const initialCustomer = $('#customerSelect').val();
            if(initialCustomer) {
                loadInvoices(initialCustomer);
                updateDueBalance(initialCustomer);
            }
        });

        $(document).ready(function() {
            initCustomerSelect2();
            
            // Save Customer via AJAX
            $('#saveCustomerBtn').click(function () {
                var cName = ($('#newCustomerName').val() || '').trim();
                var salesmanId = $('#newCustomerSalesmanId').val();
                if (!cName) {
                    Swal.fire('خطأ', 'يرجى إدخال اسم العميل', 'error');
                    return;
                }
                if (!salesmanId) {
                    Swal.fire('خطأ', 'يرجى اختيار المندوب المسؤول', 'error');
                    return;
                }
                
                var token = $('input[name="__RequestVerificationToken"]').val();
                $.post('@Url.Action("CreateCustomerAjax", "CustomerReceipts")', { name: cName, salesmanId: salesmanId, __RequestVerificationToken: token }, function (res) {
                    if (res && res.id) {
                        var newOption = new Option(res.text, res.id, true, true);
                        $('#customerSelect').append(newOption).trigger('change');
                        $('#createCustomerModal').modal('hide');
                        $('#newCustomerName').val('');
                        $('#newCustomerSalesmanId').val('');
                        Swal.fire({
                            icon: 'success',
                            title: 'نجاح',
                            text: 'تمت إضافة العميل بنجاح',
                            timer: 2000,
                            showConfirmButton: false
                        });
                    } else {
                        Swal.fire('خطأ', 'حدث خطأ غير متوقع', 'error');
                    }
                }).fail(function (xhr) {
                    var response = xhr.responseJSON || {};
                    var duplicateId = response.id;
                    if (duplicateId) {
                        var optionExists = $('#customerSelect option[value="' + duplicateId + '"]').length > 0;
                        if (!optionExists) {
                            var duplicateOption = new Option(response.text || cName, duplicateId, true, true);
                            $('#customerSelect').append(duplicateOption);
                        }
                        $('#customerSelect').val(duplicateId).trigger('change');
                    }

                    Swal.fire('تنبيه', response.message || xhr.responseText || 'تعذر الاتصال بالخادم', 'warning');
                });
            });
        })
    </script>
}
