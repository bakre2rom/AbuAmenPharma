@model IEnumerable<ItemBatch>
@{
    ViewData["Title"] = "الأدوية قريبة الانتهاء";
    var balances = ViewBag.Balances as Dictionary<int, decimal> ?? new Dictionary<int, decimal>();
}

<div class="card shadow-sm border-0 rounded-4 mt-3">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
        <div>
            <h3 class="mb-0 text-warning"><i class="bi bi-hourglass-split me-2"></i>الأدوية قريبة الانتهاء</h3>
            <p class="text-muted small mt-1">الأدوية النشطة التي تنتهي صلاحيتها خلال الـ 3 أشهر القادمة ويتوفر منها رصيد</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
            <i class="bi bi-arrow-right me-1"></i> رجوع
        </a>
    </div>

    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="expiringTable">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">اسم الدواء</th>
                        <th>رقم الباتش</th>
                        <th class="text-center">تاريخ الانتهاء</th>
                        <th class="text-center">الرصيد المتاح</th>
                        <th class="text-center">إجراء</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var batch in Model)
                    {
                        var balance = balances.TryGetValue(batch.Id, out decimal b) ? b : 0;
                        var isExpired = batch.ExpiryDate <= DateOnly.FromDateTime(DateTime.Now);
                        var badgeClass = isExpired ? "bg-danger" : "bg-warning text-dark";

                        <tr>
                            <td class="ps-3 fw-bold text-dark">@batch.Item?.NameAr</td>
                            <td class="text-muted text-nowrap">@batch.BatchNo</td>
                            <td class="text-center">
                                <span class="badge rounded-pill @badgeClass px-3 py-2">
                                    <i class="bi bi-calendar-event me-1"></i> @batch.ExpiryDate.ToString("yyyy-MM-dd")
                                </span>
                            </td>
                            <td class="text-center text-muted fw-bold">@balance</td>
                            <td class="text-center">
                                <a asp-controller="Sales" asp-action="Create" class="btn btn-sm btn-outline-success rounded-pill shadow-sm" data-bs-toggle="tooltip" title="الذهاب للبيع">
                                    <i class="bi bi-cart-check"></i> بيع
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="bi bi-shield-check text-success fs-1 d-block mb-3"></i>
                                وضع المخزون سليم، لا توجد أدوية قريبة الانتهاء حالياً.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            if ($('#expiringTable tbody tr').length > 0 && !$('#expiringTable tbody tr td').hasClass('py-4')) {
                $('#expiringTable').DataTable({
                    "language": {
                        "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/ar.json"
                    },
                    "order": [[2, "asc"]],
                    "pageLength": 5,
                    "info": true
                });
            }
        });
    </script>
}
