@model Item
@{
    ViewData["Title"] = "تعديل دواء";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card shadow-sm border-0 rounded-3 mt-3">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h3 class="mb-0 text-primary">تعديل دواء</h3>
                <p class="text-muted small">تعديل بيانات الدواء المحدد وتحديثها في النظام</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">اسم الدواء <span class="text-danger">*</span></label>
                            <input asp-for="NameAr" class="form-control bg-light" placeholder="مثال: باراسيتامول 500" />
                            <span asp-validation-for="NameAr" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">الأسم العلمي</label>
                            <input asp-for="GenericName" class="form-control bg-light" placeholder="مثال: Paracetamol" />
                            <span asp-validation-for="GenericName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">الشركة المصنعة <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <select asp-for="ManufacturerId" class="form-select bg-light" asp-items="ViewBag.ManufacturerId">
                                    <option value="">اختر الشركة...</option>
                                </select>
                                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createManufacturerModal">+</button>
                            </div>
                            <span asp-validation-for="ManufacturerId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">الوحدة <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <select asp-for="UnitId" class="form-select bg-light" asp-items="ViewBag.UnitId">
                                    <option value="">اختر الوحدة...</option>
                                </select>
                                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createUnitModal">+</button>
                            </div>
                            <span asp-validation-for="UnitId" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr class="text-muted" />

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">سعر الشراء الافتراضي</label>
                            <div class="input-group">
                                <input asp-for="DefaultPurchasePrice" class="form-control bg-light" type="number" step="0.01" />
                                <span class="input-group-text">SDG</span>
                            </div>
                            <span asp-validation-for="DefaultPurchasePrice" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">سعر البيع الافتراضي</label>
                            <div class="input-group">
                                <input asp-for="DefaultSellPrice" class="form-control bg-light" type="number" step="0.01" />
                                <span class="input-group-text">SDG</span>
                            </div>
                            <span asp-validation-for="DefaultSellPrice" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input class="form-check-input" type="checkbox" role="switch" id="isActiveSwitch" asp-for="IsActive">
                        <label class="form-check-label fw-semibold ms-2" for="isActiveSwitch">تفعيل الصنف</label>
                    </div>

                    <div class="d-flex justify-content-end gap-2 pt-2 border-top">
                        <a class="btn btn-outline-secondary px-4" asp-action="Index">إلغاء</a>
                        <button type="submit" class="btn btn-primary px-4 shadow-sm">حفظ التغييرات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Create Manufacturer Modal -->
<div class="modal fade" id="createManufacturerModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title">إضافة شركة جديدة</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-4">
                    <label class="form-label fw-semibold">اسم الشركة <span class="text-danger">*</span></label>
                    <input id="newManufacturerName" class="form-control bg-light" placeholder="مثال: الواجهة الطبية" />
                </div>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary px-4 shadow-sm" id="btnSaveManufacturer">حفظ</button>
            </div>
        </div>
    </div>
</div>

<!-- Create Unit Modal -->
<div class="modal fade" id="createUnitModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title">إضافة وحدة جديدة</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-4">
                    <label class="form-label fw-semibold">اسم الوحدة <span class="text-danger">*</span></label>
                    <input id="newUnitName" class="form-control bg-light" placeholder="مثال: شريط، علبة..." />
                </div>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary px-4 shadow-sm" id="btnSaveUnit">حفظ</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const createManufacturerUrl = '@Url.Action("CreateAjax", "Manufacturers")';
        const createUnitUrl = '@Url.Action("CreateAjax", "Units")';

        function normalizeName(value) {
            return (value || '').trim().toLowerCase();
        }

        function findMatchingOption(selectElement, normalizedValue) {
            return Array.from(selectElement.options).find(opt => normalizeName(opt.text) === normalizedValue) || null;
        }

        document.getElementById('btnSaveManufacturer').addEventListener('click', function () {
            const name = document.getElementById('newManufacturerName').value.trim();
            if (!name) return alert('يرجى إدخال اسم الشركة');
            
            fetch(createManufacturerUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ 'nameAr': name })
            }).then(async r => {
                const data = await r.json().catch(() => null);
                if (!r.ok) {
                    throw { data };
                }
                return data;
            }).then(data => {
                const opt = new Option(data.name, data.id, true, true);
                document.getElementById('ManufacturerId').appendChild(opt);
                bootstrap.Modal.getInstance(document.getElementById('createManufacturerModal')).hide();
                document.getElementById('newManufacturerName').value = '';
            }).catch(err => {
                const message = err?.data?.message || err?.data || 'تعذر حفظ الشركة، حاول مرة أخرى.';
                Swal.fire('خطأ', message, 'error');
            });
        });

        document.getElementById('btnSaveUnit').addEventListener('click', function () {
            const name = document.getElementById('newUnitName').value.trim();
            if (!name) return alert('يرجى إدخال اسم الوحدة');

            const normalizedName = normalizeName(name);
            const unitSelect = document.getElementById('UnitId');
            const existingOption = findMatchingOption(unitSelect, normalizedName);
            if (existingOption) {
                unitSelect.value = existingOption.value;
                Swal.fire('تنبيه', 'هذه الوحدة موجودة مسبقاً وتم اختيارها تلقائياً.', 'warning');
                return;
            }
            
            fetch(createUnitUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ 'nameAr': name })
            }).then(async r => {
                const data = await r.json().catch(() => null);
                if (!r.ok) {
                    throw { status: r.status, data };
                }
                return data;
            }).then(data => {
                const opt = new Option(data.name, data.id, true, true);
                unitSelect.appendChild(opt);
                bootstrap.Modal.getInstance(document.getElementById('createUnitModal')).hide();
                document.getElementById('newUnitName').value = '';
            }).catch(err => {
                const duplicateId = err?.data?.id;
                const duplicateName = err?.data?.name;
                const message = err?.data?.message || err?.data || 'تعذر حفظ الوحدة، حاول مرة أخرى.';

                if (duplicateId) {
                    let option = Array.from(unitSelect.options).find(o => o.value === String(duplicateId));
                    if (!option) {
                        option = new Option(duplicateName || name, duplicateId, true, true);
                        unitSelect.appendChild(option);
                    }
                    unitSelect.value = String(duplicateId);
                }

                Swal.fire('تنبيه', message, 'warning');
            });
        });
    </script>
}
