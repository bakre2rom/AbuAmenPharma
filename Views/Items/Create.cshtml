@model Item
@{
    ViewData["Title"] = "إضافة دواء";
}

<h3 class="mb-3">إضافة دواء</h3>

<form asp-action="Create" method="post" class="card p-3">
    <div asp-validation-summary="All" class="text-danger mb-2"></div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">اسم الدواء</label>
            <input asp-for="NameAr" class="form-control" placeholder="مثال: باراسيتامول 500" />
            <span asp-validation-for="NameAr" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label">الأسم العلمي</label>
            <input asp-for="GenericName" class="form-control" placeholder="GenericName" />
            <span asp-validation-for="GenericName" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">الشركة المصنعة</label>
            <select asp-for="ManufacturerId" class="form-select" asp-items="ViewBag.ManufacturerId">
                <option value="">اختر...</option>
            </select>
            <span asp-validation-for="ManufacturerId" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label">الوحدة</label>
            <select asp-for="UnitId" class="form-select" asp-items="ViewBag.UnitId">
                <option value="">اختر...</option>
            </select>
            <span asp-validation-for="UnitId" class="text-danger"></span>
        </div>
    </div>

    <hr />

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">سعر الشراء الافتراضي</label>
            <input asp-for="DefaultPurchasePrice" class="form-control" type="number" step="0.01" value="0" />
            <span asp-validation-for="DefaultPurchasePrice" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label">سعر البيع الافتراضي</label>
            <input asp-for="DefaultSellPrice" class="form-control" type="number" step="0.01" value="0" />
            <span asp-validation-for="DefaultSellPrice" class="text-danger"></span>
        </div>

        @* <div class="col-md-4 mb-3">
            <label class="form-label">حد إعادة الطلب</label>
            <input asp-for="ReorderLevel" class="form-control" type="number" step="1" value="0" />
            <span asp-validation-for="ReorderLevel" class="text-danger"></span>
        </div> *@
    </div>

    <div class="form-check mb-3">
        <input class="form-check-input" asp-for="IsActive" />
        <label class="form-check-label">نشط</label>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success">حفظ</button>
        <a class="btn btn-secondary" asp-action="Index">رجوع</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}