@{
    ViewData["Title"] = "الأدوية";
}

<div class="row justify-content-center">
    <div class="col-lg-12">
        <div class="card shadow-sm border-0 rounded-4 mt-3">
            <div class="card-header bg-white border-bottom-0 py-2 px-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-capsule me-2"></i>الأدوية</h5>
                <a class="btn btn-sm btn-primary px-3 rounded-pill shadow-sm" asp-action="Create">
                    <i class="bi bi-plus-lg me-1"></i> إضافة دواء
                </a>
            </div>
            <div class="card-body p-2">
                <div class="table-responsive">
                    <table id="itemsTable" class="table table-sm table-hover table-striped table-bordered w-100 align-middle" style="margin-top: 5px; font-size: 0.88rem;">
                        <thead class="table-light text-center small">
                            <tr>
                                <th>الاسم</th>
                                <th>الباركود</th>
                                <th>الوحدة</th>
                                <th>الشركة المصنعة</th>
                                <th>سعر البيع</th>
                                <th style="width:160px;">إجراءات</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .table > :not(caption) > * > * {
        padding: 0.5rem 0.4rem !important;
        color: #495057;
    }
</style>

@section Scripts {
    <link href="~/lib/datatables/css/jquery.datatables.min.css" rel="stylesheet" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/datatables/js/jquery.datatables.min.js"></script>

    <script>
        $(function () {
            $('#itemsTable').DataTable({
                processing: true,
                serverSide: true,
                filter: true,
                orderMulti: false,
                pageLength: 5,
                ajax: {
                    url: '@Url.Action("LoadData", "Items")',
                    type: 'POST'
                },
                columns: [
                    { data: 'nameAr', name: 'NameAr' },
                    { data: 'barCode', name: 'BarCode' },
                    { data: 'unitName', name: 'UnitName' },
                    { data: 'manufacturerName', name: 'ManufacturerName' },
                    { 
                        data: 'defaultSellPrice', 
                        name: 'DefaultSellPrice',
                        render: function(data) { return '<span class="fw-bold text-success">' + data + '</span>'; }
                    },
                    {
                        data: 'id',
                        orderable: false,
                        searchable: false,
                        render: function (data) {
                            return `
                                <div class="d-flex justify-content-center gap-2">
                                    <a class="btn btn-outline-info floating-action-btn" href="/ItemBatches?itemId=${data}" data-bs-toggle="tooltip" title="دفعات الصنف"><i class="bi bi-boxes"></i></a>
                                    <a class="btn btn-outline-secondary floating-action-btn" href="/Items/Edit/${data}" data-bs-toggle="tooltip" title="تعديل البيانات"><i class="bi bi-pencil"></i></a>
                                    <a class="btn btn-outline-danger floating-action-btn" href="/Items/Disable/${data}" data-bs-toggle="tooltip" title="تعطيل"><i class="bi bi-x-lg"></i></a>
                                </div>
                            `;
                        }
                    }
                ],
                language: {
                    search: "بحث:",
                    lengthMenu: "عرض _MENU_ مدخلات",
                    info: "عرض _START_ إلى _END_ من أصل _TOTAL_ مدخل",
                    infoEmpty: "تعرض 0 إلى 0 من أصل 0 سجل",
                    zeroRecords: "لم يتم العثور على سجلات متطابقة",
                    paginate: { first: "الأول", last: "الأخير", next: "التالي", previous: "السابق" },
                    processing: '<div class="spinner-border text-primary" role="status"><span class="visually-hidden">جاري التحميل...</span></div>'
                }
            });
        });
    </script>
}