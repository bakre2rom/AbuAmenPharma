@model IEnumerable<Item>
@{
    ViewData["Title"] = "نواقص الأدوية";
    var balances = ViewBag.Balances as Dictionary<int, decimal> ?? new Dictionary<int, decimal>();
}

<div class="card shadow-sm border-0 rounded-4 mt-3">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
        <div>
            <h3 class="mb-0 text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>نواقص الأدوية (تحت حد الطلب)</h3>
            <p class="text-muted small mt-1">قائمة بالأصناف التي وصل رصيدها إلى مستوى إعادة الطلب أو أقل</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
            <i class="bi bi-arrow-right me-1"></i> رجوع
        </a>
    </div>

    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="lowStockTable">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">اسم الدواء</th>
                        <th>الشركة / الوحدة</th>
                        <th class="text-center">الرصيد الحالي</th>
                        <th class="text-center">حد إعادة الطلب</th>
                        <th class="text-center">إجراء</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var balance = balances.TryGetValue(item.Id, out decimal b) ? b : 0;
                        <tr>
                            <td class="ps-3">
                                <div class="fw-bold text-dark">@item.NameAr</div>
                                @if (!string.IsNullOrEmpty(item.BarCode))
                                {
                                    <div class="small text-muted"><i class="bi bi-upc-scan me-1"></i>@item.BarCode</div>
                                }
                            </td>
                            <td>
                                <div><i class="bi bi-building text-secondary me-1"></i> @item.Manufacturer?.NameAr</div>
                                <div class="small text-muted">@item.Unit?.NameAr</div>
                            </td>
                            <td class="text-center">
                                <span class="badge rounded-pill bg-danger px-3 py-2 fs-6">@balance</span>
                            </td>
                            <td class="text-center text-muted fw-bold filter-reorder">@item.ReorderLevel</td>
                            <td class="text-center">
                                <a asp-controller="Purchases" asp-action="Create" class="btn btn-sm btn-outline-primary rounded-pill shadow-sm" data-bs-toggle="tooltip" title="شراء الصنف">
                                    <i class="bi bi-cart-plus"></i> شراء
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="bi bi-check-circle text-success fs-1 d-block mb-3"></i>
                                جميع الأرصدة ممتازة، ولا توجد نواقص حالياً.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            if ($('#lowStockTable tbody tr').length > 0 && !$('#lowStockTable tbody tr td').hasClass('py-4')) {
                $('#lowStockTable').DataTable({
                    "language": {
                        "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/ar.json"
                    },
                    "order": [[2, "asc"]],
                    "pageLength": 5,
                    "info": true
                });
            }
        });
    </script>
}
