@using AbuAmenPharma.ViewModels
@model SaleReturnCreateVM
@{
    ViewData["Title"] = "إنشاء مرتجع مبيعات";
}
<h3 class="mb-3">إنشاء مرتجع مبيعات</h3>
<div class="text-muted mb-2">
    العميل: <strong>@Model.CustomerName</strong> — فاتورة: <strong>@Model.SaleId</strong>
</div>

<form asp-action="CreateFromSale" method="post" class="card p-3">
    <input type="hidden" asp-for="SaleId" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <div class="row">
        <div class="col-md-3 mb-3">
            <label class="form-label fw-semibold">المتبقي على العميل</label>
            <input class="form-control fw-bold text-danger bg-light" value="@Model.CustomerPendingAmount.ToString("N2")" readonly disabled />
            <div class="form-text mt-0">الرصيد المتبقي على العميل حالياً</div>
        </div>
        <div class="col-md-3 mb-3">
            <label class="form-label fw-semibold">تاريخ المرتجع <span class="text-danger">*</span></label>
            <input asp-for="ReturnDate" class="form-control" type="datetime-local" data-val="true" data-val-required="تاريخ المرتجع مطلوب" />
            <span asp-validation-for="ReturnDate" class="text-danger small d-block"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label class="form-label fw-semibold">الخصم الإضافي</label>
            <input asp-for="Discount" class="form-control" type="number" step="0.01" value="0" data-val="true" data-val-number="يجب أن يكون الخصم رقماً" />
            <span asp-validation-for="Discount" class="text-danger small d-block"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label class="form-label fw-semibold">ملاحظات</label>
            <input asp-for="Notes" class="form-control" placeholder="سبب الإرجاع..." />
        </div>
    </div>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>الصنف</th>
                <th class="text-end">المباع</th>
                <th class="text-end">مرتجع سابق</th>
                <th class="text-end">المتاح</th>
                <th class="text-end">السعر</th>
                <th style="width:160px;">مرتجع الآن</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Lines.Count; i++)
            {
                <tr>
                    <td>
                        @Model.Lines[i].ItemName
                        <input type="hidden" name="Lines[@i].SaleLineId" value="@Model.Lines[i].SaleLineId" />
                    </td>
                    <td class="text-end">@Model.Lines[i].SoldQty</td>
                    <td class="text-end">@Model.Lines[i].AlreadyReturnedQty</td>
                    <td class="text-end"><strong>@Model.Lines[i].AvailableToReturn</strong></td>
                    <td class="text-end">@Model.Lines[i].UnitPrice</td>
                    <td>
                        <input name="Lines[@i].ReturnQty" class="form-control" type="number" step="0.01" value="0" />
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex gap-2">
        <button class="btn btn-success fw-bold px-4 shadow-sm">حفظ المرتجع</button>
        <a class="btn btn-outline-secondary" asp-action="Index">رجوع</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}