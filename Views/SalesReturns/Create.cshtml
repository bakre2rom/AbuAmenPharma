@model IEnumerable<Sale>
@{
    ViewData["Title"] = "مرتجع مبيعات";
}
<h3 class="mb-3">مرتجع مبيعات</h3>
<div class="alert alert-info">اختر فاتورة بيع لعمل مرتجع منها</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>#</th>
            <th>التاريخ</th>
            <th>العميل</th>
            <th>الصافي</th>
            <th>المتبقي</th>
            <th style="width:140px;"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Id</td>
                <td>@s.SaleDate</td>
                <td>@s.Customer?.Name</td>
                <td>@s.NetTotal</td>
                <td>@s.RemainingAmount</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-primary" asp-action="CreateFromSale" asp-route-saleId="@s.Id">اختيار</a>
                </td>
            </tr>
        }
    </tbody>
</table>