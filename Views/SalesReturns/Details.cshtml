@model SaleReturn
@{
    ViewData["Title"] = $"تفاصيل مرتجع مبيعات #{Model.Id}";
    var allocs = ViewBag.Allocations as List<SaleReturnAllocation> ?? new List<SaleReturnAllocation>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="mb-0">تفاصيل مرتجع مبيعات #@Model.Id</h3>
        <div class="text-muted">
            فاتورة: <strong>#@Model.SaleId</strong> —
            العميل: <strong>@Model.Customer?.Name</strong> —
            التاريخ: <strong>@Model.ReturnDate</strong>
        </div>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" target="_blank" asp-action="Print" asp-route-id="@Model.Id">طباعة</a>

        @if (Model.IsActive)
        {
            <a class="btn btn-outline-danger" asp-action="Disable" asp-route-id="@Model.Id">تعطيل</a>
        }

        <a class="btn btn-secondary" asp-action="Index">رجوع</a>
    </div>
</div>

<table class="table table-sm table-bordered">
    <tr><th style="width:220px;">الحالة</th><td>@(Model.IsActive ? "نشط" : "معطل")</td></tr>
    <tr><th>الإجمالي</th><td>@Model.SubTotal</td></tr>
    <tr><th>الخصم</th><td>@Model.Discount</td></tr>
    <tr><th>الصافي</th><td><strong>@Model.NetTotal</strong></td></tr>
    <tr><th>ملاحظات</th><td>@(string.IsNullOrWhiteSpace(Model.Notes) ? "-" : Model.Notes)</td></tr>
</table>

<h5 class="mt-3">بنود المرتجع</h5>

<table class="table table-bordered align-middle">
    <thead>
        <tr>
            <th>الصنف</th>
            <th class="text-end">الكمية</th>
            <th class="text-end">السعر</th>
            <th class="text-end">الإجمالي</th>
            <th>توزيع الدفعات (Reverse FIFO)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var line in Model.Lines)
        {
            var lineAllocs = allocs.Where(a => a.SaleReturnLineId == line.Id).ToList();

            <tr>
                <td>@line.Item?.NameAr</td>
                <td class="text-end">@line.Qty</td>
                <td class="text-end">@line.UnitPrice</td>
                <td class="text-end">@line.LineTotal</td>
                <td>
                    @if (lineAllocs.Count == 0)
                    {
                        <span class="text-muted">-</span>
                    }
                    else
                    {
                                <table class="table table-sm table-bordered mb-0">
                                    <tbody>
                                        <tr class="table-light fw-semibold">
                                            <td>دفعة</td>
                                            <td>تاريخ الانتهاء</td>
                                            <td class="text-end">كمية</td>
                                        </tr>
                                        @foreach (var a in lineAllocs)
                                        {
                                            <tr>
                                                <td>@a.Batch?.BatchNo</td>
                                                <td>@(a.Batch != null ? a.Batch.ExpiryDate.ToString("yyyy-MM-dd") : "-")</td>
                                                <td class="text-end">@a.Qty</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
