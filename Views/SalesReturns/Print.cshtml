@model SaleReturn
@{
    Layout = "~/Views/Shared/_InvoicePrintLayout.cshtml";
    ViewData["PrintPageTitle"] = $"مرتجع مبيعات #{Model.Id}";
    ViewData["PrintCloseUrl"] = Url.Action("Index", "SalesReturns");
    var allocations = ViewBag.Allocations as List<SaleReturnAllocation> ?? new List<SaleReturnAllocation>();
}

<div class="container">
    <div class="header">
        <div class="header-right">
            <div class="company-name">شركة أبو آمن للأدوية</div>
            <div class="invoice-title-badge">مرتجع مبيعات</div>
            
            <div class="invoice-metadata" style="background:transparent; border:none; padding:0; margin-bottom:5px;">
                <div class="metadata-item">
                    <span class="label">رقم المرتجع:</span>
                    <span class="value">#@Model.Id</span>
                </div>
                <div class="metadata-item">
                    <span class="label">تاريخ المرتجع:</span>
                    <span class="value">@Model.ReturnDate.ToString("yyyy-MM-dd")</span>
                </div>
                <div class="metadata-item">
                    <span class="label">فاتورة البيع الأصلية:</span>
                    <span class="value">#@Model.SaleId</span>
                </div>
            </div>

            <div class="invoice-metadata">
                <div class="metadata-item">
                    <span class="label">العميل:</span>
                    <span class="value">@Model.Customer?.Name</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Notes))
                {
                    <div class="metadata-item">
                        <span class="label">ملاحظات:</span>
                        <span class="value">@Model.Notes</span>
                    </div>
                }
            </div>
        </div>
        <div class="header-left d-flex align-items-center justify-content-center" style="width: 150px; height: 120px;">
            <img src="@Url.Content("~/img/abuamen-mark.svg")" style="width: 100%; height: 100%; object-fit: contain; display: block;" alt="شعار أبو آمن" />
        </div>
    </div>

    <table class="items-table">
        <thead>
            <tr>
                <th class="text-center" style="width: 50px;">#</th>
                <th>الصنف</th>
                <th style="width: 150px;">رقم الباتش</th>
                <th style="width: 150px;">تاريخ الانتهاء</th>
                <th class="text-center" style="width: 80px;">الكمية</th>
                <th class="text-center" style="width: 100px;">السعر</th>
                <th class="text-center" style="width: 120px;">الإجمالي</th>
            </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
                foreach (var line in Model.Lines)
                {
                    var lineAllocs = allocations.Where(x => x.SaleReturnLineId == line.Id).ToList();
                    <tr>
                        <td class="text-center">@(i++)</td>
                        <td>@line.Item?.NameAr</td>
                        <td class="text-center">
                            @if (lineAllocs.Count == 0) { <span class="muted">-</span> }
                            else {
                                foreach (var a in lineAllocs) { <div>@a.Batch?.BatchNo</div> }
                            }
                        </td>
                        <td class="text-center">
                            @if (lineAllocs.Count == 0) { <span class="muted">-</span> }
                            else {
                                foreach (var a in lineAllocs) { <div>@(a.Batch != null ? a.Batch.ExpiryDate.ToString("yyyy-MM-dd") : "-")</div> }
                            }
                        </td>
                        <td class="text-center">@line.Qty.ToString("0.##")</td>
                        <td class="text-center">@line.UnitPrice.ToString("N2")</td>
                        <td class="text-center">@line.LineTotal.ToString("N2")</td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <div class="totals-section">
        <table class="totals-table">
            <tr>
                <td class="label">إجمالي البنود</td>
                <td class="value">@Model.SubTotal.ToString("N2")</td>
            </tr>
            @if (Model.Discount > 0)
            {
                <tr>
                    <td class="label">الخصم</td>
                    <td class="value">- @Model.Discount.ToString("N2")</td>
                </tr>
            }
            <tr class="grand-total">
                <td class="label">صافي قيمة المرتجع</td>
                <td class="value">@Model.NetTotal.ToString("N2")</td>
            </tr>
        </table>
    </div>

    <partial name="_InvoicePrintFooter" />
</div>
