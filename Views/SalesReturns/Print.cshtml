@model SaleReturn
@{
    Layout = null;
    var allocs = ViewBag.Allocations as List<SaleReturnAllocation> ?? new List<SaleReturnAllocation>();
}

<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>مرتجع مبيعات #@Model.Id</title>
    <style>
        body {
            font-family: Tahoma, Arial;
            margin: 20px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 12px;
        }

        .company {
            font-size: 20px;
            font-weight: bold;
        }

        .sub {
            color: #444;
            font-size: 12px;
            margin-top: 4px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid #000;
            padding: 6px;
            font-size: 12px;
        }

        th {
            background: #f2f2f2;
        }

        .text-center {
            text-align: center;
        }

        .text-end {
            text-align: left;
        }
        /* RTL end */
        .print-btn {
            margin-bottom: 12px;
        }
        @@media print {
            .print-btn

        {
            display: none;
        }

        body {
            margin: 0;
        }

        }
    </style>
</head>
<body>

    <div class="print-btn">
        <button onclick="window.print()">🖨 طباعة</button>
        <button onclick="window.close()">إغلاق</button>
    </div>

    <div class="header">
        <div>
            <div class="company">شركة أبو أمين للأدوية</div>
            <div class="sub">مرتجع مبيعات</div>
        </div>
        <div class="text-end">
            <div><strong>رقم المرتجع:</strong> @Model.Id</div>
            <div><strong>فاتورة:</strong> #@Model.SaleId</div>
            <div><strong>التاريخ:</strong> @Model.ReturnDate</div>
        </div>
    </div>

    <table style="margin-bottom:10px;">
        <tr>
            <td><strong>العميل:</strong> @Model.Customer?.Name</td>
            <td><strong>ملاحظات:</strong> @(string.IsNullOrWhiteSpace(Model.Notes) ? "-" : Model.Notes)</td>
        </tr>
    </table>

    <table>
        <thead>
            <tr>
                <th style="width:5%;">م</th>
                <th>الصنف</th>
                <th style="width:12%;" class="text-center">الكمية</th>
                <th style="width:12%;" class="text-center">السعر</th>
                <th style="width:15%;" class="text-center">الإجمالي</th>
            </tr>
        </thead>
        <tbody>
            @{
                var i = 1;
                foreach (var line in Model.Lines)
                {
                    <tr>
                        <td class="text-center">@i</td>
                        <td>
                            @line.Item?.NameAr
                            <div class="sub">
                                @{
                                    var la = allocs.Where(a => a.SaleReturnLineId == line.Id).ToList();
                                    if (la.Count > 0)
                                    {
                                        <strong>دفعات:</strong>
                                        foreach (var a in la)
                                        {
                                            <span>
                                                دفعة @a.Batch?.BatchNo (انتهاء: @(a.Batch?.ExpiryDate.ToString() ?? "-")) كمية: @a.Qty  |
                                            </span>
                                        }
                                    }
                                }
                            </div>
                        </td>
                        <td class="text-center">@line.Qty</td>
                        <td class="text-center">@line.UnitPrice</td>
                        <td class="text-center">@line.LineTotal</td>
                    </tr>
                    i++;
                }
            }
        </tbody>
    </table>

    <br />

    <table style="width:320px; margin-right:auto;">
        <tr><th>الإجمالي</th><td class="text-center">@Model.SubTotal</td></tr>
        <tr><th>الخصم</th><td class="text-center">@Model.Discount</td></tr>
        <tr><th>الصافي</th><td class="text-center"><strong>@Model.NetTotal</strong></td></tr>
    </table>

    <div class="sub" style="margin-top:12px;">شكراً لتعاملكم معنا.</div>

</body>
</html>