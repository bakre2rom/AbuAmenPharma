@using AbuAmenPharma.ViewModels
@model CustomerStatementVM
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>كشف حساب عميل</title>

    <style>
        body {
            direction: rtl;
            font-family: Arial;
            font-size: 13px;
            padding: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        table, th, td {
            border: 1px solid #000;
        }

        th, td {
            padding: 5px;
        }

        .text-end {
            text-align: left;
        }

        .header {
            text-align: center;
            margin-bottom: 20px;
        }

        .summary {
            width: 50%;
            margin-top: 15px;
        }

            .summary td {
                padding: 6px;
            }

    </style>
</head>
<body onload="window.print()">

    <div class="header">
        <h3>شركة أبو آمن للأدوية</h3>
        <div>كشف حساب عميل</div>
        <div>العميل: @Model.CustomerName</div>
        <div>الفترة: @Model.From.ToString("yyyy-MM-dd") إلى @Model.To.ToString("yyyy-MM-dd")</div>
        <hr />
    </div>

    <table>
        <thead>
            <tr>
                <th>التاريخ</th>
                <th>النوع</th>
                <th>#</th>
                <th>ملاحظات</th>
                <th>مدين</th>
                <th>دائن</th>
                <th>الرصيد</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td colspan="6"><strong>رصيد افتتاحي</strong></td>
                <td>@Model.OpeningBalance.ToString("N2")</td>
            </tr>

            @foreach (var l in Model.Lines)
            {
                <tr>
                    <td>@l.Date.ToString("yyyy-MM-dd")</td>
                    <td>@l.TypeName</td>
                    <td>@l.RefId</td>
                    <td>@l.Notes</td>
                    <td>@l.Debit.ToString("N2")</td>
                    <td>@l.Credit.ToString("N2")</td>
                    <td>@l.RunningBalance.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>

    <table class="summary">
        <tr>
            <td>إجمالي مدين</td>
            <td>@Model.TotalDebit.ToString("N2")</td>
        </tr>
        <tr>
            <td>إجمالي دائن</td>
            <td>@Model.TotalCredit.ToString("N2")</td>
        </tr>
        <tr>
            <td><strong>الرصيد الختامي</strong></td>
            <td><strong>@Model.ClosingBalance.ToString("N2")</strong></td>
        </tr>
    </table>

</body>
</html>