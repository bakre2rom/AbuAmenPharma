@using AbuAmenPharma.ViewModels
@model List<PricingListVM>
@{
    ViewData["Title"] = "قائمة أسعار الأدوية";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1 text-primary fw-bold">قائمة الأسعار</h3>
        <p class="text-muted mb-0">كشف بأسعار المبيع للأدوية والأصناف المتوفرة (مرتبة حسب الشركة المصنعة)</p>
    </div>
    <div class="d-print-none">
        <button onclick="window.print()" class="btn btn-outline-secondary me-2">
            <i class="bi bi-printer me-1"></i> طباعة
        </button>
        <a asp-action="PricingList" class="btn btn-light border">
            <i class="bi bi-arrow-clockwise"></i> تحديث
        </a>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4 overflow-hidden">
    <div class="card-body p-3">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-end" id="pricingTable">
                <thead class="bg-primary text-white">
                    <tr>
                        <th class="ps-3 d-none">الشركة المصنعة</th> <!-- Hidden but used for grouping -->
                        <th>اسم الصنف / الدواء</th>
                        <th>البادش (Batch)</th>
                        <th>الوحدة</th>
                        <th class="text-center">تاريخ الانتهاء</th>
                        <th class="text-center">الكمية المتاحة</th>
                        <th class="text-center pe-3">سعر المبيع</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        string lastManufacturer = "";
                    }
                    @foreach (var item in Model)
                    {
                        if (item.Manufacturer != lastManufacturer)
                        {
                            <tr class="group-header bg-light border-bottom-2 border-primary">
                                <td colspan="7" class="ps-3 font-bold text-primary py-2 text-start">
                                    <i class="bi bi-building me-2"></i> <strong>@item.Manufacturer</strong>
                                </td>
                            </tr>
                            lastManufacturer = item.Manufacturer;
                        }
                        <tr>
                            <td class="d-none">@item.Manufacturer</td>
                            <td class="ps-3 fw-bold text-dark">@item.ItemName</td>
                            <td><code class="text-dark">@item.BatchNo</code></td>
                            <td>@item.Unit</td>
                            <td class="text-center">
                                @{
                                    var daysToExpiry = item.ExpiryDate.DayNumber - DateOnly.FromDateTime(DateTime.Today).DayNumber;
                                    var badgeClass = daysToExpiry < 0 ? "bg-danger" : (daysToExpiry <= 90 ? "bg-warning text-dark" : "bg-light text-dark border");
                                }
                                <span class="badge @badgeClass font-monospace px-2">@item.ExpiryDate.ToString("yyyy/MM/dd")</span>
                            </td>
                            <td class="text-center font-monospace @(item.Balance <= 5 ? "text-danger fw-bold" : "text-muted")">
                                @item.Balance.ToString("N0")
                            </td>
                            <td class="text-center pe-3 fw-bold fs-5 text-primary">
                                @item.SellPrice.ToString("N2") <small class="fw-normal text-muted" style="font-size: 0.7rem">ج.س</small>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">لا توجد أدوية متوفرة حالياً في المخزون</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/lib/datatables/css/datatables.bootstrap.min.css" rel="stylesheet" />
    <style>
        .group-header { border-right: 5px solid var(--bs-primary); }
        #pricingTable_filter input { border-radius: 20px; padding: 5px 15px; border: 1px solid #ddd; }
        #pricingTable_filter label { font-weight: bold; color: #555; }
        
        @@media print {
            .navbar, .d-print-none, footer, #pricingTable_filter, #pricingTable_length, #pricingTable_info, #pricingTable_paginate { 
                display: none !important; 
            }
            .container-fluid { padding: 0 !important; margin: 0 !important; }
            .card { border: none !important; box-shadow: none !important; }
            .table { width: 100% !important; border-collapse: collapse !important; font-size: 11pt !important; }
            .table thead { display: table-header-group !important; }
            .table th { background-color: #f8f9fa !important; color: black !important; border: 1px solid #dee2e6 !important; }
            .table td { border: 1px solid #dee2e6 !important; }
            body { background: white !important; }
        }
    </style>
}

@section Scripts {
    <script src="~/lib/datatables/js/jquery.datatables.min.js"></script>
    <script src="~/lib/datatables/js/datatables.bootstrap.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#pricingTable').DataTable({
                ordering: false, // Disabled because we are using manual grouping output from server
                paging: false,   // Usually pricing lists are printed as a whole, but search is kept
                language: {
                    search: "بحث:",
                    searchPlaceholder: "اسم الصنف، البادش، الشركة...",
                    info: "عرض _TOTAL_ صنف",
                    infoEmpty: "لا توجد نتائج",
                    infoFiltered: "(مركزة من _MAX_ صنف)"
                },
            });
        });
    </script>
}
