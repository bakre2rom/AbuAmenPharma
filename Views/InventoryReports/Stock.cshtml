@model IEnumerable<AbuAmenPharma.ViewModels.InventoryStockVM>
@{
    bool isValuation = Model.FirstOrDefault()?.IsValuationReport ?? false;
    ViewData["Title"] = isValuation ? "تقييم قيمة المخزون" : "حركة المخزون العامة";
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-white py-3 border-bottom-0 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold">
            <i class="bi @(isValuation ? "bi-currency-dollar text-success" : "bi-layers text-primary") me-2"></i>@ViewData["Title"]
        </h5>
        
        <form method="get" class="d-flex w-auto" style="min-width:300px;">
            <div class="input-group input-group-sm">
                <input type="text" name="q" class="form-control" placeholder="ابحث باسم الصنف أو الدفعة..." value="@ViewBag.Q" />
                <button type="submit" class="btn btn-primary px-3"><i class="bi bi-search"></i></button>
            </div>
        </form>
    </div>
    
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="stockTable">
                <thead class="table-light">
                    <tr>
                        <th>الصنف</th>
                        <th>الدفعة</th>
                        <th class="text-center">تاريخ الانتهاء</th>
                        <th class="text-center">سعر الشراء</th>
                        <th class="text-center">الرصيد المتاح</th>
                        @if (isValuation)
                        {
                            <th class="text-center">قيمة المخزون</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="@(isValuation ? 6 : 5)" class="text-center text-muted py-4">
                                <i class="bi bi-exclamation-circle fs-4 d-block mb-2 text-warning"></i>
                                لا توجد بيانات متاحة
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.ItemName</td>
                                <td><span class="badge bg-secondary">@(string.IsNullOrEmpty(item.BatchNo) ? "بدون دفعة" : item.BatchNo)</span></td>
                                <td class="text-center">
                                    @if(item.ExpiryDate.HasValue)
                                    {
                                        var daysRemaining = item.ExpiryDate.Value.DayNumber - DateOnly.FromDateTime(DateTime.Today).DayNumber;
                                        <span class="badge @(daysRemaining < 0 ? "bg-danger" : daysRemaining < 90 ? "bg-warning" : "bg-success")">
                                            @item.ExpiryDate.Value.ToString("yyyy-MM-dd")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-center fw-semibold text-muted">@item.PurchasePrice.ToString("N2")</td>
                                <td class="text-center">
                                    <span class="badge @(item.RemainingQty <= 0 ? "bg-danger" : "bg-primary")">
                                        @item.RemainingQty.ToString("N2")
                                    </span>
                                </td>
                                @if (isValuation)
                                {
                                    <td class="text-center fw-bold text-success">@item.TotalValue.ToString("N2")</td>
                                }
                            </tr>
                        }
                    }
                </tbody>
                @if (isValuation && Model.Any())
                {
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="5" class="text-end fw-bold">إجمالي قيمة المخزون العام:</td>
                            <td class="text-center fw-bold fs-5 text-success">@Model.Sum(x => x.TotalValue).ToString("N2")</td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Simple search highlighting/etc could be placed here if needed
    </script>
}
