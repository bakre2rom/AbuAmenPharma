@{
    ViewData["Title"] = "المشتريات";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>المشتريات</h3>
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-action="Create">فاتورة شراء جديدة</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-bordered" id="purchasesTable" style="width:100%">
            <thead>
                <tr>
                    <th>#</th>
                    <th>التاريخ</th>
                    <th>المورد</th>
                    <th>الإجمالي</th>
                    <th>مرحل؟</th>
                    <th>أجراءات</th>
                </tr>
            </thead>
        </table>
    </div>
</div>

@section Styles {
    <link href="~/lib/datatables/css/datatables.bootstrap.min.css" rel="stylesheet" />
}

@section Scripts {
    <script src="~/lib/datatables/js/jquery.datatables.min.js"></script>
    <script src="~/lib/datatables/js/datatables.bootstrap.min.js"></script>

    <script>
        $(document).ready(function() {
            $('#purchasesTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: {
                    url: '@Url.Action("GetPurchaseData", "Purchases")',
                    type: 'POST'
                },
                columns: [
                    { data: 'id' },
                    {
                        data: 'purchaseDate',
                    },
                    { data: 'supplierName' },
                    {
                        data: 'netTotal',
                        render: function(data) {
                            return Number(data).toFixed(2);
                        }
                    },
                    {
                        data: 'isPosted',
                        render: function(data) {
                            if(data){
                                return '<span>نعم</span>';
                            }
                            return '<span>لا</span>';
                        }
                    },
                    {
                        data: 'id',
                        render: function(data) {
                            return `<a class="btn btn-sm btn-outline-primary" href="/Purchases/Details/${data}">تفاصيل</a>`;
                        }
                    }
                ],
                order: [[0, 'desc']],
                pageLength: 25
            });
        });
    </script>
}

