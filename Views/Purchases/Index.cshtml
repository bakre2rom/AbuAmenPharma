@{
    ViewData["Title"] = "المشتريات";
}

<partial name="ERP_Components/_ERPRowActionsStyles" />

<div class="row justify-content-center">
    <div class="col-lg-12">
        <div class="d-flex justify-content-between align-items-center mb-3 mt-1">
            <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-bag-check me-2 text-primary"></i> إدارة المشتريات</h5>
            <div class="d-flex gap-2">
                <a class="btn btn-sm btn-primary px-3 rounded-pill shadow-sm d-flex align-items-center gap-2" asp-action="Create">
                    <i class="bi bi-plus-lg"></i> إضافة فاتورة شراء
                </a>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-3">
                <div class="table-responsive">
                    <table class="table table-hover align-middle text-center w-100" id="purchasesTable">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center">رقم الفاتورة</th>
                                <th class="text-center">المورد</th>
                                <th class="text-center">التاريخ</th>
                                <th class="text-center">الإجمالي</th>
                                <th class="text-center">الحالة</th>
                                <th class="text-center" style="width:120px;">العمليات</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/lib/datatables/css/datatables.bootstrap.min.css" rel="stylesheet" />
}

@section Scripts {
    <script src="~/lib/datatables/js/jquery.datatables.min.js"></script>
    <script src="~/lib/datatables/js/datatables.bootstrap.min.js"></script>

    <partial name="ERP_Components/_ERPDataTableScript" model='new AbuAmenPharma.ViewModels.ERPDataTableConfig { 
        TableId = "purchasesTable", 
        AjaxUrl = Url.Action("GetPurchaseData", "Purchases"),
        ColumnsJson = "[{\"data\":\"id\",\"render\":function(data){return `<span class=\\\"fw-bold text-primary\\\">PO-${data}#</span>`;}},{\"data\":\"supplierName\",\"render\":function(data){return `<span class=\\\"fw-bold text-dark\\\">${data||\"بدون مورد\"}</span>`;}},{\"data\":\"purchaseDate\",\"render\":function(data){if(!data)return \"-\";return new Date(data).toISOString().split(\"T\")[0];}},{\"data\":\"netTotal\",\"render\":function(data){return `<span class=\\\"fw-bold text-success\\\">${Number(data).toLocaleString(undefined,{minimumFractionDigits:2})}</span> <small class=\\\"text-muted\\\">جنيه سوداني</small>`;}},{\"data\":\"isPosted\",\"render\":function(data){if(data)return `<span class=\\\"badge rounded-pill bg-success px-3\\\">مكتمل</span>`;return `<span class=\\\"badge rounded-pill bg-warning text-dark px-3\\\">مسودة</span>`;}},{\"data\":\"id\",\"render\":function(data){return `<div class=\\\"row-actions\\\"><a href=\\\"/Purchases/Details/${data}\\\" class=\\\"row-btn row-btn-view\\\" title=\\\"عرض\\\"><i class=\\\"bi bi-eye\\\"></i></a><a href=\\\"/Purchases/Print/${data}\\\" target=\\\"_blank\\\" class=\\\"row-btn row-btn-print\\\" title=\\\"طباعة\\\"><i class=\\\"bi bi-printer\\\"></i></a></div>`;}}]",
        PageLength = 6
    }' />
}
