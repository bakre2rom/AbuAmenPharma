@using AbuAmenPharma.ViewModels
@model PurchaseCreateVM
@{
    ViewData["Title"] = "فاتورة شراء جديدة";
}

<form asp-action="Create" method="post" id="purchaseForm">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <div class="row g-3" style="min-height: calc(100vh - 120px);">

        <!-- ===== RIGHT PANEL: Invoice Lines ===== -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 pt-3 pb-2 px-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-cart-plus me-1 text-primary"></i> بنود فاتورة الشراء</h5>
                    <button type="button" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm" id="addRowBtn">
                        <i class="bi bi-plus-lg me-1"></i>إضافة بند
                    </button>
                </div>
                <div class="card-body p-2 pt-0">
                    <div class="table-responsive" style="max-height: calc(100vh - 280px); overflow-y: auto;">
                        <table class="table table-sm table-hover align-middle mb-0" id="linesTable">
                            <thead class="table-light" style="position: sticky; top: 0; z-index: 2;">
                                <tr>
                                    <th style="width:35%; min-width:200px;">الصنف</th>
                                    <th style="width:18%;" class="text-center">تاريخ الانتهاء</th>
                                    <th style="width:12%;" class="text-center">الكمية</th>
                                    <th style="width:15%;" class="text-center">سعر الوحدة</th>
                                    <th style="width:15%;" class="text-center">الإجمالي</th>
                                    <th style="width:5%;" class="text-center"></th>
                                </tr>
                            </thead>
                            <tbody id="linesTableBody">
                                <!-- rows added dynamically -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== LEFT PANEL: Sidebar Summary ===== -->
        <div class="col-lg-4">
            <div class="position-lg-sticky" style="top: 80px;">
                <div class="card border-0 shadow-sm rounded-4 mb-3">
                    <div class="card-header bg-primary bg-gradient text-white border-0 rounded-top-4 py-2 px-3">
                        <h6 class="mb-0 fw-bold small"><i class="bi bi-info-circle me-2"></i>معلومات الفاتورة</h6>
                    </div>
                    <div class="card-body p-2 mt-n1">
                        <div class="row g-1 mb-2">
                            <div class="col-12">
                                <label class="form-label tiny-label fw-semibold mb-0">المورد <span class="text-danger">*</span></label>
                                <div class="d-flex gap-1">
                                    <select asp-for="SupplierId" class="form-control form-control-sm rounded-2" id="supplierSelect" asp-items="ViewBag.SupplierId">
                                        <option value="">...</option>
                                    </select>
                                    <button type="button" class="btn btn-sm btn-primary px-2" data-bs-toggle="modal" data-bs-target="#createSupplierModal"><i class="bi bi-plus-lg"></i></button>
                                </div>
                            </div>
                            <div class="col-6">
                                <label class="form-label tiny-label fw-semibold mb-0">التاريخ <span class="text-danger">*</span></label>
                                <input asp-for="PurchaseDate" class="form-control form-control-sm rounded-2 bg-light py-0" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" />
                            </div>
                            <div class="col-6">
                                <label class="form-label tiny-label fw-semibold mb-0">رقم الفاتورة</label>
                                <input asp-for="InvoiceNo" class="form-control form-control-sm rounded-2" placeholder="رقم..." />
                            </div>
                            <div class="col-6">
                                <label class="form-label tiny-label fw-semibold mb-0">الخصم الإجمالي</label>
                                <input asp-for="Discount" class="form-control form-control-sm rounded-2" id="totalDiscount" type="number" step="0.01" value="0" />
                            </div>
                            <div class="col-6 align-self-end">
                                <div class="text-muted tiny-label text-end mb-0">الصافي</div>
                                <div class="fw-bold text-primary text-end fs-6" id="netGrandTotal" style="line-height:1">0.00</div>
                            </div>
                            <div class="col-12">
                                <label class="form-label tiny-label fw-semibold mb-0">ملاحظات</label>
                                <input asp-for="Notes" class="form-control form-control-sm rounded-2" placeholder="ملاحظات..." />
                            </div>
                        </div>

                        <hr class="my-1 opacity-25">

                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="text-muted small">إجمالي البنود:</span>
                            <span id="subTotalLabel" class="small fw-semibold">0.00</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="text-muted small">الخصم:</span>
                            <span id="discountLabel" class="small text-danger fw-semibold">0.00</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                            <span class="fw-bold text-dark">الصافي:</span>
                            <span id="netTotalLabel" class="fw-bold text-primary h5 mb-0">0.00</span>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="row g-2">
                    <div class="col-9">
                        <button class="btn btn-primary w-100 shadow-sm rounded-3 py-2 fw-bold" type="submit">
                            <i class="bi bi-check-lg me-1"></i>حفظ الفاتورة
                        </button>
                    </div>
                    <div class="col-3">
                        <a class="btn btn-outline-secondary w-100 rounded-3 py-2" asp-action="Index">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- Create Supplier Modal -->
<div class="modal fade" id="createSupplierModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title">إضافة مورد جديد</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-4">
                    <label class="form-label fw-semibold">اسم المورد <span class="text-danger">*</span></label>
                    <input type="text" id="newSupplierName" class="form-control bg-light" placeholder="اسم المورد..." required />
                </div>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary px-4 shadow-sm" id="saveSupplierBtn">حفظ</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/lib/select2/css/select2.min.css" rel="stylesheet" />
    <style>
        .select2-container--default .select2-selection--single {
            height: 31px;
            border: 1px solid #ced4da;
            border-radius: 6px;
            font-size: 0.875rem;
        }
        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 29px;
            font-size: 0.875rem;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 29px;
        }
        .select2-dropdown {
            z-index: 9999;
        }
        #linesTable th {
            font-size: 0.8rem;
            font-weight: 600;
            white-space: nowrap;
        }
        #linesTable td {
            vertical-align: middle;
            padding: 0.35rem 0.4rem;
        }
        .rowTotal {
            font-weight: bold;
            color: #198754;
        }
        @@media (min-width: 992px) {
            .position-lg-sticky {
                position: sticky !important;
                top: 80px;
            }
        }
        .tiny-label {
            font-size: 0.75rem;
            color: #6c757d;
        }
    </style>
}

@section Scripts {
    <script src="~/lib/select2/js/select2.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        let rowCounter = 0;

        function parseNumber(value) {
            if (!value) return 0;
            return parseFloat(value.toString().replace(/[^\d.-]/g, '')) || 0;
        }

        function formatMoney(value) {
            return parseNumber(value).toFixed(2);
        }

        function initItemSelect2(selector) {
            $(selector).select2({
                placeholder: 'اختر صنف...',
                allowClear: true,
                dir: 'rtl',
                theme: "default",
                ajax: {
                    url: '@Url.Action("SearchItems", "Purchases")',
                    dataType: 'json',
                    delay: 250,
                    data: function(params) {
                        return { term: params.term };
                    },
                    processResults: function(data) {
                        return { results: data };
                    }
                }
            }).on('select2:select', function(e) {
                const $row = $(this).closest('tr');
                const itemId = e.params.data.id;
                
                $.get('@Url.Action("GetItemPrice", "Purchases")', { id: itemId }, function(res) {
                    if (res && res.price) {
                        $row.find('.priceInput').val(formatMoney(res.price));
                        calculateTotals();
                    }
                });
            });
        }

        // Initialize standalone Supplier Select2 if needed (it currently uses a ViewBag SelectList)
        // But for better look let's use standard form control

        function createNewRow() {
            const rowId = rowCounter++;
            const t = new Date();
            t.setFullYear(t.getFullYear() + 2); // Default expiry 2 years forward
            const defaultExpiry = t.toISOString().split('T')[0];

            const html = `
                <tr data-row="${rowId}">
                    <td>
                        <input type="hidden" name="Lines.Index" value="${rowId}" />
                        <select name="Lines[${rowId}].ItemId" class="form-control form-control-sm itemSelect" style="width:100%" required></select>
                    </td>
                    <td>
                        <input type="date" name="Lines[${rowId}].ExpiryDate" class="form-control form-control-sm text-center" value="${defaultExpiry}" required />
                    </td>
                    <td>
                        <input type="number" name="Lines[${rowId}].Qty" class="form-control form-control-sm qtyInput text-center" step="0.01" min="0.01" value="0" required />
                    </td>
                    <td>
                        <input type="number" name="Lines[${rowId}].UnitCost" class="form-control form-control-sm priceInput text-center" step="0.01" min="0" value="0" required />
                    </td>
                    <td class="text-center align-middle">
                        <span class="rowTotal">0.00</span>
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-outline-danger removeRow" style="width:28px;height:28px;padding:0;line-height:28px;">
                            <i class="bi bi-x"></i>
                        </button>
                    </td>
                </tr>
            `;

            $('#linesTableBody').append(html);
            initItemSelect2(`#linesTableBody tr:last .itemSelect`);
        }

        function calculateTotals() {
            let subtotal = 0;
            $('#linesTableBody tr').each(function() {
                const $row = $(this);
                const qty = parseNumber($row.find('.qtyInput').val());
                const price = parseNumber($row.find('.priceInput').val());
                const lineTotal = qty * price;
                $row.find('.rowTotal').text(formatMoney(lineTotal));
                subtotal += lineTotal;
            });

            const discount = parseNumber($('#totalDiscount').val());
            const netTotal = Math.max(0, subtotal - discount);

            $('#subTotalLabel').text(formatMoney(subtotal));
            $('#discountLabel').text(formatMoney(discount));
            $('#netTotalLabel').text(formatMoney(netTotal));
            $('#netGrandTotal').text(formatMoney(netTotal));
        }

        function reindexRows() {
            let index = 0;
            $('#linesTableBody tr').each(function() {
                const $row = $(this);
                $row.attr('data-row', index);
                $row.find('input[name="Lines.Index"]').val(index);
                $row.find('.itemSelect').attr('name', `Lines[${index}].ItemId`);
                $row.find('input[name*="ExpiryDate"]').attr('name', `Lines[${index}].ExpiryDate`);
                $row.find('.qtyInput').attr('name', `Lines[${index}].Qty`);
                $row.find('.priceInput').attr('name', `Lines[${index}].UnitCost`);
                index++;
            });
            rowCounter = index;
        }

        $(document).ready(function() {
            // First Row
            createNewRow();

            $('#addRowBtn').click(function() {
                createNewRow();
            });

            $('#linesTable').on('click', '.removeRow', function() {
                if ($('#linesTableBody tr').length > 1) {
                    const $select = $(this).closest('tr').find('.itemSelect');
                    if ($select.data('select2')) $select.select2('destroy');
                    $(this).closest('tr').remove();
                    reindexRows();
                    calculateTotals();
                } else {
                    Swal.fire('تنبيه', 'يجب وجود بند واحد على الأقل', 'warning');
                }
            });

            $('#linesTable').on('input', '.qtyInput, .priceInput', function() {
                calculateTotals();
            });

            $('#totalDiscount').on('input', function() {
                calculateTotals();
            });

            // Save Supplier
            $('#saveSupplierBtn').click(function () {
                const sName = $('#newSupplierName').val();
                if (!sName) return Swal.fire('خطأ', 'يرجى إدخال اسم المورد', 'error');

                $.post('@Url.Action("CreateSupplierAjax", "Purchases")', { name: sName }, function (res) {
                    if (res && res.id) {
                        const newOption = new Option(res.text, res.id, true, true);
                        $('#supplierSelect').append(newOption).trigger('change');
                        $('#createSupplierModal').modal('hide');
                        $('#newSupplierName').val('');
                        Swal.fire({ icon: 'success', title: 'نجاح', text: 'تمت إضافة المورد بنجاح', timer: 2000, showConfirmButton: false });
                    }
                });
            });

            $('#purchaseForm').submit(function(e) {
                if ($('#linesTableBody tr').length === 0) {
                    e.preventDefault();
                    Swal.fire('خطأ', 'أضف بند واحد على الأقل', 'error');
                }
            });

            // Initialize select2 on supplier if you want searchability
            $('#supplierSelect').select2({
                dir: 'rtl',
                placeholder: 'اختر المورد...'
            });
        });
    </script>
}